    private void CompleteServiceEntry(WeTacoo.Domain.Execution.Shift shift, WeTacoo.Domain.Execution.Entities.ServiceEntry se)
    {
        if (se.Completed) return;
        se.Complete($"Firma_{se.ClientInfo?.ClientName ?? "Operatore"}_{DateTime.UtcNow:HHmmss}");
        State.PublishEvent(new WeTacoo.Domain.Events.ServiceExecutedEvent(shift.Id, se.Id, se.ServiceId, "Completed"));
        Snackbar.Add($"ServiceEntry {se.Type} completata", Severity.Success);
        State.NotifyStateChanged();
    }

    private void CompletaShift(WeTacoo.Domain.Execution.Shift shift)
    {
        if (shift.Status != "InProgress") return;
        if (!shift.ServiceEntries.All(se => se.Completed)) return;

        shift.Complete();

        // Classifica gli oggetti in base al tipo di ServiceEntry
        var ritiroObjectIds = new List<string>();   // censiti durante il ritiro → a magazzino
        var deliveredCount = 0;
        var disposedCount = 0;

        foreach (var se in shift.ServiceEntries)
        {
            switch (se.Type)
            {
                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.Ritiro:
                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.TraslocoRitiro:
                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.RitiroTraslocoDeposito:
                    // Oggetti censiti nei Task di questa entry
                    var censiti = shift.Tasks.Where(t => t.ServiceEntryId == se.Id).SelectMany(t => t.ObjectIds).Distinct().ToList();
                    ritiroObjectIds.AddRange(censiti);
                    break;

                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.Consegna:
                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.TraslocoConsegna:
                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.ConsegnaTrasloco:
                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.ConsegnaTraslocoDeposito:
                    // Oggetti selezionati nella Quotation → Delivered
                    var svcConsegna = FindServiceBookedForWoId(se.ServiceId);
                    if (svcConsegna != null)
                    {
                        foreach (var objId in svcConsegna.SelectedObjectIds)
                        {
                            var obj = State.Objects.FirstOrDefault(o => o.Id == objId);
                            if (obj == null) continue;
                            var oldStatus = obj.Status.ToString();
                            obj.Deliver(shift.MissionId);
                            State.PublishEvent(new WeTacoo.Domain.Events.ObjectStateChangedEvent(obj.Id, oldStatus, obj.Status.ToString(), "Deliver"));
                            deliveredCount++;
                        }
                    }
                    break;

                case WeTacoo.Domain.Execution.Enums.ServiceEntryType.Smaltimento:
                    var svcSm = FindServiceBookedForWoId(se.ServiceId);
                    if (svcSm != null)
                    {
                        foreach (var objId in svcSm.SelectedObjectIds)
                        {
                            var obj = State.Objects.FirstOrDefault(o => o.Id == objId);
                            if (obj == null) continue;
                            var oldStatus = obj.Status.ToString();
                            obj.Dispose(shift.MissionId);
                            State.PublishEvent(new WeTacoo.Domain.Events.ObjectStateChangedEvent(obj.Id, oldStatus, obj.Status.ToString(), "Dispose"));
                            disposedCount++;
                        }
                    }
                    break;

            }
        }

        // WarehouseOperation IN per gli oggetti ritirati
        var warehouse = State.Warehouses.FirstOrDefault();
        if (warehouse != null && ritiroObjectIds.Count > 0)
        {
            var whOp = new WeTacoo.Domain.Execution.WarehouseOperation
            {
                WarehouseId = warehouse.Id,
                MissionId = shift.MissionId,
                VehicleId = shift.Mission?.Vehicles.FirstOrDefault(),
                OperationType = "IN",
                ObjectIds = ritiroObjectIds.ToList()
            };
            whOp.Start();
            whOp.Complete();
            State.WarehouseOperations.Add(whOp);

            foreach (var objId in ritiroObjectIds)
            {
                var obj = State.Objects.FirstOrDefault(o => o.Id == objId);
                if (obj != null && obj.Status != WeTacoo.Domain.Execution.Enums.ObjectStatus.OnWarehouse)
                {
                    var oldStatus = obj.Status.ToString();
                    obj.UnloadToWarehouse(warehouse.Id, shift.MissionId);
                    State.PublishEvent(new WeTacoo.Domain.Events.ObjectStateChangedEvent(obj.Id, oldStatus, obj.Status.ToString(), "UnloadToWarehouse"));
                }
            }
        }

        // Emit OperationCompleted -> EventHandler does WO InEsecuzione -> DaVerificare (se tutti gli Shift associati sono Completata)
        foreach (var se in shift.ServiceEntries)
        {
            State.PublishEvent(new WeTacoo.Domain.Events.OperationCompletedEvent(shift.Id, se.ServiceId));
        }

        var msg = $"Shift completato. Ritirati: {ritiroObjectIds.Count}, Consegnati: {deliveredCount}, Smaltiti: {disposedCount}";
        Snackbar.Add(msg, Severity.Success);
        State.NotifyStateChanged();
    }

    // ══════════════════════════════════════════════════════════════
    // SEGNALA PROBLEMA -> WorkOrder In Pausa
    // ══════════════════════════════════════════════════════════════
    private void SegnalaProblema(WeTacoo.Domain.Execution.Shift shift)
    {
        try
        {
            foreach (var se in shift.ServiceEntries)
            {
                var wo = State.WorkOrders.FirstOrDefault(w => w.Id == se.ServiceId);
                if (wo == null) continue;

                if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.InExecution)
                {
                    var oldStatus = wo.Status.ToString();
                    wo.MettiInPausa("Problema segnalato dal team");
                    State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderStatusChangedEvent(wo.Id, oldStatus, wo.Status.ToString(), "Problema segnalato dal team"));
                    State.PublishEvent(new WeTacoo.Domain.Events.OperationInterruptedEvent(shift.Id, wo.Id, "Problema segnalato dal team"));
                    State.PublishEvent(new WeTacoo.Domain.Events.RichiedeInterventoEvent(wo.Id, wo.ServiceBookedId, "Problema segnalato dal team operativo"));
                }
            }
            // Pausa anche lo Shift per coerenza con WO InPausa
            shift.Pause();
            Snackbar.Add("Problema segnalato, Shift e WorkOrder in pausa — intervento Commercial richiesto", Severity.Warning);
            State.NotifyStateChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    // ══════════════════════════════════════════════════════════════
    // CHIUSURA ANTICIPATA (UC-13) e ANNULLA (Commercial, in tutti gli stati non terminali)
    // ══════════════════════════════════════════════════════════════
    private void ChiusuraAnticipataWo(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        wo.ChiusuraAnticipata("Commercial decide chiusura prematura");
        // Mette in pausa gli shift ancora attivi (non completati) — Ops verifichera' i dati effettivi
        foreach (var sh in State.Shifts.Where(s => s.Status is "InProgress" or "Paused" && s.ServiceEntries.Any(se => se.ServiceId == wo.Id)))
        {
            if (sh.Status == "InProgress") sh.Pause();
        }
        State.PublishEvent(new WeTacoo.Domain.Events.ChiusuraAnticipataEvent(wo.Id, wo.ServiceBookedId, "Commercial decide chiusura"));
        Snackbar.Add($"WO {wo.Id} → Da verificare (chiusura anticipata)", Severity.Warning);
        State.NotifyStateChanged();
    }

    private void CancelServiceBooked(WeTacoo.Domain.Commercial.Entities.ServiceBooked svc)
    {
        var wo = svc.WorkOrderId != null ? State.WorkOrders.FirstOrDefault(w => w.Id == svc.WorkOrderId) : null;

        // UC-13: se l'esecuzione e' gia' partita (almeno un task completato),
        // la cancellazione diventa Chiusura Anticipata — il servizio sara' verificato e concluso,
        // non annullato. ServiceBooked resta nel suo stato corrente e diverra' Completato alla verifica.
        bool executionStarted = wo != null && wo.Status is
            WeTacoo.Domain.Operational.Enums.WorkOrderStatus.InExecution
            or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Paused
            or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToVerify;

        if (executionStarted && wo != null)
        {
            if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.InExecution)
                wo.ChiusuraAnticipata("Cancellazione richiesta da Commercial con parte gia' completata");
            else if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Paused)
                wo.InterventoRisoltoChiudi("Cancellazione richiesta da Commercial con parte gia' completata");
            // DaVerificare: gia' in attesa di verifica, non tocco

            // Shift ancora attivi → Sospesa; Shift Created (non iniziati) → Annullata
            foreach (var sh in State.Shifts.Where(s => s.ServiceEntries.Any(se => se.ServiceId == wo.Id)))
            {
                if (sh.Status == "Created") sh.Status = "Cancelled";
                else if (sh.Status is "InProgress" or "Paused") sh.Status = "Suspended";
            }
            State.PublishEvent(new WeTacoo.Domain.Events.ChiusuraAnticipataEvent(wo.Id, svc.Id, "Commercial richiede chiusura con parte completata"));
            Snackbar.Add($"Servizio {svc.Type}: esecuzione parziale gia' svolta → Chiusura anticipata (UC-13). Ops verifichera' i dati effettivi e concludera'.", Severity.Warning);
            State.NotifyStateChanged();
            return;
        }

        // Cancellazione piena (esecuzione non ancora avviata)
        svc.Annulla();
        wo?.Annulla("Commercial");
        if (wo != null)
        {
            foreach (var sh in State.Shifts.Where(s => s.ServiceEntries.Any(se => se.ServiceId == wo.Id)))
            {
                // Shift non ancora partiti -> Annullata; Shift gia' in esecuzione/pausa -> Sospesa
                if (sh.Status == "Created") sh.Status = "Cancelled";
                else if (sh.Status is "InProgress" or "Paused") sh.Status = "Suspended";
            }
        }
        State.PublishEvent(new WeTacoo.Domain.Events.ServizioCancellatoEvent(svc.Id, wo?.Id));
        Snackbar.Add($"Servizio {svc.Type} annullato", Severity.Error);
        State.NotifyStateChanged();
    }

    // ══════════════════════════════════════════════════════════════
    // INTERVENTO RISOLTO — Commercial sblocca WorkOrder da In pausa
    // ══════════════════════════════════════════════════════════════
    private readonly Dictionary<string, string> _interventoNotes = new();
    private string GetInterventoNote(string woId) => _interventoNotes.TryGetValue(woId, out var v) ? v : "";
    private void SetInterventoNote(string woId, string v) => _interventoNotes[woId] = v;

    private WeTacoo.Domain.Commercial.Entities.ServiceBooked? FindServiceForWo(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        foreach (var d in State.Deals)
            foreach (var q in d.Quotations)
                foreach (var s in q.Services)
                    if (s.Id == wo.ServiceBookedId) return s;
        return null;
    }

    private WeTacoo.Domain.Commercial.Entities.ServiceBooked? FindServiceBookedForWoId(string woId)
    {
        var wo = State.WorkOrders.FirstOrDefault(w => w.Id == woId);
        if (wo?.ServiceBookedId == null) return null;
        foreach (var d in State.Deals)
            foreach (var q in d.Quotations)
                foreach (var s in q.Services)
                    if (s.Id == wo.ServiceBookedId) return s;
        return null;
    }

    private void ResolveWoRiprogramma(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        var note = GetInterventoNote(wo.Id);
        wo.InterventoRisoltoRiprogramma(note);
        FindServiceForWo(wo)?.InterventoRisolto();
        State.PublishEvent(new WeTacoo.Domain.Events.InterventoRisoltoEvent(wo.Id, "Riprogramma", note));
        Snackbar.Add($"WO {wo.Id} sbloccato — riprogrammabile", Severity.Info);
        _interventoNotes.Remove(wo.Id);
        State.NotifyStateChanged();
    }

    private void ResolveWoRiprendi(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        var note = GetInterventoNote(wo.Id);
        wo.InterventoRisoltoRiprendi(note);
        FindServiceForWo(wo)?.InterventoRisolto();
        // Riattiva gli Shift in pausa collegati al WO
        foreach (var sh in State.Shifts.Where(s => s.Status == "Paused" && s.ServiceEntries.Any(se => se.ServiceId == wo.Id)))
        {
            sh.Resume();
        }
        State.PublishEvent(new WeTacoo.Domain.Events.InterventoRisoltoEvent(wo.Id, "Riprendi", note));
        Snackbar.Add($"WO {wo.Id} ripreso in esecuzione — Shift riattivati", Severity.Warning);
        _interventoNotes.Remove(wo.Id);
        State.NotifyStateChanged();
    }

    private void ResolveWoChiudi(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        var note = GetInterventoNote(wo.Id);
        wo.InterventoRisoltoChiudi(note);
        State.PublishEvent(new WeTacoo.Domain.Events.InterventoRisoltoEvent(wo.Id, "Chiudi", note));
        Snackbar.Add($"WO {wo.Id} portato a Da verificare — Ops verifichera' i dati effettivi", Severity.Success);
        _interventoNotes.Remove(wo.Id);
        State.NotifyStateChanged();
    }

    // Sopralluogo e' ora un normale ServiceBooked/WorkOrder (DDD5 §4.8 review 2026-04-16).
    // I metodi CompleteInspectionForService / CreateInspectionForService sono stati rimossi:
    // per richiedere un sopralluogo si aggiunge un ServiceBooked di Type=Sopralluogo alla Quotation
    // e lo si processa con il flusso standard (AccettaServizio -> SegnaComePronto -> WorkOrder Sopralluogo).

    // ══════════════════════════════════════════════════════════════
    // CREATE TRASBORDO
    // ══════════════════════════════════════════════════════════════
    private void CreateTrasbordo()
    {
        try
        {
            if (string.IsNullOrEmpty(_selectedLeadId)) return;
            var lead = State.Leads.FirstOrDefault(l => l.Id == _selectedLeadId);
            if (lead == null) return;

            // Create WorkOrder Trasbordo (operational, no ServiceBooked)
            var wo = new WeTacoo.Domain.Operational.WorkOrder
            {
                Type = WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational,
                ServiceType = new WeTacoo.Domain.Operational.ValueObjects.ServiceTypeVO(
                    WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Trasbordo, false, false, null),
                ContactName = $"{lead.Personal.FirstName} {lead.Personal.LastName}",
                Commercial = new WeTacoo.Domain.Operational.ValueObjects.CommercialData(lead.Id, null, null, [], false),
            };
            State.WorkOrders.Add(wo);

            State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderCreatedEvent(wo.Id, wo.Type.ToString(), "Trasbordo"));
            Snackbar.Add("WorkOrder Trasbordo (Operativo) creato", Severity.Success);
            State.NotifyStateChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

