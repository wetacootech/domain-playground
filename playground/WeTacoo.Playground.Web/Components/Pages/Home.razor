    // ══════════════════════════════════════════════════════════════
    // ADJUSTMENT FLOW — Post-mismatch guided adjustment
    // ══════════════════════════════════════════════════════════════
    private void ApplyAdjustment(WeTacoo.Domain.Operational.WorkOrder wo, WeTacoo.Domain.Commercial.Deal deal)
    {
        try
        {
            var delta = wo.ActualVolume - wo.EstimatedVolume;

            // Registra la differenza nello storico del WO — NON modifica ActivePlan
            wo.Notes = (wo.Notes ?? "") + $"\n[{DateTime.UtcNow:u}] Differenza registrata: stimato {wo.EstimatedVolume:F1} m³, effettivo {wo.ActualVolume:F1} m³, delta {delta:+0.0;-0.0} m³";

            // Conclude the WO after adjustment
            var oldStatus = wo.Status.ToString();
            wo.VerificaEConcludi("Sales");
            State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderStatusChangedEvent(wo.Id, oldStatus, wo.Status.ToString(), $"Adjustment: delta {delta:+0.0;-0.0} m³"));

            // Trigger cross-BC cascade
            State.PublishEvent(new WeTacoo.Domain.Events.ServizioCompletatoEvent(
                wo.Id, wo.ServiceBookedId, wo.ActualVolume, delta != 0, $"Delta {delta:+0.0;-0.0} m³"));

            Snackbar.Add($"Differenza registrata: {delta:+0.0;-0.0} m³ — WO concluso. Crea nuovi pagamenti dalla Quotation se necessario.", Severity.Success);
            State.NotifyStateChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    // ══════════════════════════════════════════════════════════════
    // CONFIRM ADJUSTMENT — Quotation ToAdjust -> Completed
    // ══════════════════════════════════════════════════════════════
    private void ConfirmAdjustmentAndComplete(WeTacoo.Domain.Commercial.Deal deal, WeTacoo.Domain.Commercial.Entities.Quotation q)
    {
        q.Complete(); // ToAdjust -> Completed

        // Deal cascade: check if all quotations done
        if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Converted)
        {
            if (deal.Type == WeTacoo.Domain.Commercial.Enums.DealType.Recurring)
            {
                deal.Activate();
                State.PublishEvent(new WeTacoo.Domain.Events.DealActivatedEvent(deal.Id));
            }
            else
            {
                deal.Conclude();
                State.PublishEvent(new WeTacoo.Domain.Events.DealConcludedEvent(deal.Id, deal.LeadId));
            }
        }
        else if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Active)
        {
            var allQuotDone = deal.Quotations.Where(qq => qq.IsAccepted)
                .All(qq => qq.Status is WeTacoo.Domain.Commercial.Enums.QuotationStatus.Completed or WeTacoo.Domain.Commercial.Enums.QuotationStatus.ToAdjust);
            if (allQuotDone)
            {
                var objCount = State.Objects.Count(o => o.DealId == deal.Id && o.Status == WeTacoo.Domain.Execution.Enums.ObjectStatus.OnWarehouse);
                deal.TryCloseIfNoObjectsRemaining(objCount);
                if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Concluded)
                    State.PublishEvent(new WeTacoo.Domain.Events.DealConcludedEvent(deal.Id, deal.LeadId));
            }
        }

        Snackbar.Add("Adeguamento confermato — Quotation completata", Severity.Success);
        State.NotifyStateChanged();
    }

    // ══════════════════════════════════════════════════════════════
    // CREATE PAYMENT FOR QUOTATION (disponibile in qualsiasi momento)
    // ══════════════════════════════════════════════════════════════
    private void CreatePaymentForQuotation(WeTacoo.Domain.Commercial.Deal deal, WeTacoo.Domain.Commercial.Entities.Quotation q)
    {
        if (_newPaymentAmount <= 0) { Snackbar.Add("Inserisci un importo", Severity.Warning); return; }

        var lead = State.Leads.FirstOrDefault(l => l.Id == deal.LeadId);
        var finClient = State.FinancialClients.FirstOrDefault(c => c.CommercialLeadId == lead?.Id);
        if (finClient == null && lead != null)
        {
            finClient = new WeTacoo.Domain.Financial.FinancialClient
            {
                CommercialLeadId = lead.Id,
                BillingName = $"{lead.Personal.FirstName} {lead.Personal.LastName}"
            };
            State.FinancialClients.Add(finClient);
            lead.FinancialClientId = finClient.Id;
        }

        var payment = new WeTacoo.Domain.Financial.Payment
        {
            ClientId = finClient?.Id ?? "",
            DealId = deal.Id,
            QuotationId = q.Id,
            PaymentType = _newPaymentType
        };
        payment.Products.Add(new WeTacoo.Domain.Financial.SimplifiedProduct
        {
            Name = _newPaymentType == "Recurring" ? "Pagamento ricorrente" : "Pagamento one-off",
            Description = $"Pagamento per Quotation {q.Id}",
            Price = _newPaymentAmount
        });
        payment.AddCharge(_newPaymentAmount);

        State.Payments.Add(payment);
        State.PublishEvent(new WeTacoo.Domain.Events.PaymentCreatedEvent(payment.Id, deal.Id));
        Snackbar.Add($"Pagamento {payment.Id} creato: {_newPaymentAmount:C} ({_newPaymentType})", Severity.Success);
        _newPaymentAmount = 0;
        State.NotifyStateChanged();
    }

    // ══════════════════════════════════════════════════════════════
    // ASSIGN WO TO EXISTING MISSION
    // ══════════════════════════════════════════════════════════════
    private string? _assignMissionWoId;
    private string? _selectedExistingMissionId;

    private void AssignWOToMission(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        if (string.IsNullOrEmpty(_selectedExistingMissionId)) return;
        try
        {
            foreach (var planning in State.Plannings)
            {
                var mission = planning.Missions.FirstOrDefault(m => m.Id == _selectedExistingMissionId);
                if (mission != null)
                {
                    mission.ServiceRefs.Add(new WeTacoo.Domain.Operational.Entities.ServiceRef(wo.Id, _missionVolumePercent));

                    // Add ServiceEntry to existing Shift
                    var existingShift = State.Shifts.FirstOrDefault(s => s.MissionId == mission.Id);
                    if (existingShift != null)
                    {
                        string? dealId = null;
                        string? leadId = wo.Commercial?.LeadId;
                        WeTacoo.Domain.Execution.Entities.ClientData? clientData = null;
                        if (leadId != null)
                        {
                            var lead = State.Leads.FirstOrDefault(l => l.Id == leadId);
                            var deal = State.Deals.FirstOrDefault(d => d.LeadId == leadId);
                            dealId = deal?.Id;
                            if (lead != null)
                                clientData = new WeTacoo.Domain.Execution.Entities.ClientData(
                                    $"{lead.Personal.FirstName} {lead.Personal.LastName}", lead.Personal.Phone ?? "");
                        }
                        var entryType = MapServiceEntryType(wo);
                        existingShift.AddServiceEntry(wo.Id, dealId, leadId, entryType, clientData);
                    }

                    Snackbar.Add($"WO assegnato a Mission {mission.Id}", Severity.Success);
                    _assignMissionWoId = null;
                    _selectedExistingMissionId = null;
                    State.NotifyStateChanged();
                    return;
                }
            }
            Snackbar.Add("Mission non trovata", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private List<WeTacoo.Domain.Operational.Entities.Mission> GetAvailableMissions()
    {
        return State.Plannings
            .SelectMany(p => p.Missions.Where(m => !m.IsCancelled)
                .Select(m => m))
            .ToList();
    }

    // ══════════════════════════════════════════════════════════════
    // MINI GUIDA — analizza stato e suggerisce prossimi passi
    // ══════════════════════════════════════════════════════════════
    record GuideStep(string Icon, Color Color, string Action, string Description, string? Where);

    private List<GuideStep> GetNextSteps(WeTacoo.Domain.Commercial.Lead lead)
    {
        var steps = new List<GuideStep>();
        var deals = GetLeadDeals();

        // Nessun deal -> crea deal
        if (!deals.Any())
        {
            steps.Add(new(Icons.Material.Filled.Add, Color.Primary, "Crea un Deal", "Apri una trattativa per questo cliente (Deposito o Trasloco)", "Workspace"));
            return steps;
        }

        foreach (var deal in deals)
        {
            var dealLabel = $"Deal {deal.Id[..Math.Min(6, deal.Id.Length)]}";

            // Deal da qualificare
            if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.ToQualify)
            {
                steps.Add(new(Icons.Material.Filled.CheckCircle, Color.Warning, $"Qualifica {dealLabel}", "Contatta il cliente e qualifica la trattativa", "Workspace -> Deal"));
                continue;
            }

            // Deal qualificato/in trattativa -> serve quotation
            if (deal.Status is WeTacoo.Domain.Commercial.Enums.DealStatus.Qualified or WeTacoo.Domain.Commercial.Enums.DealStatus.InNegotiation)
            {
                if (!deal.Quotations.Any(q => q.IsAccepted))
                {
                    if (!deal.Quotations.Any() || deal.Quotations.All(q => q.Status == WeTacoo.Domain.Commercial.Enums.QuotationStatus.Archived))
                        steps.Add(new(Icons.Material.Filled.Description, Color.Primary, $"Crea Quotation su {dealLabel}", "Aggiungi servizi, prodotti e scegli le date dagli slot disponibili", "Workspace -> Deal -> Aggiungi Quotation"));
                    else
                        steps.Add(new(Icons.Material.Filled.CheckCircle, Color.Success, $"Accetta Quotation su {dealLabel}", "Finalizza il preventivo — crea WorkOrder e Payment", "Workspace -> Deal -> Quotation -> Accetta"));
                }
                continue;
            }

            // Deal convertito/attivo -> guarda i WorkOrder
            if (deal.Status is WeTacoo.Domain.Commercial.Enums.DealStatus.Converted or WeTacoo.Domain.Commercial.Enums.DealStatus.Active)
            {
                var svcList = deal.Quotations.Where(q => q.IsAccepted).SelectMany(q => q.Services).ToList();

                foreach (var svc in svcList)
                {
                    var wo = svc.WorkOrderId != null ? State.WorkOrders.FirstOrDefault(w => w.Id == svc.WorkOrderId) : null;
                    var svcLabel = wo != null ? $"{wo.ServiceType.Type}" : $"{svc.Type}";

                    // Check ServiceBooked status first (Commercial side)
                    if (svc.Status == WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.ToComplete)
                    {
                        steps.Add(new(Icons.Material.Filled.Quiz, Color.Info, $"Completa questionario per {svcLabel}", "Conferma i dati del servizio per renderlo programmabile", "Workspace -> Deal -> Quotation -> Questionario completato"));
                        continue;
                    }

                    // Check WorkOrder status (Operational side)
                    if (wo == null) continue;

                    switch (wo.Status)
                    {
                        case WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule:
                            steps.Add(new(Icons.Material.Filled.CalendarMonth, Color.Warning, $"Programma {svcLabel}", "Scegli data e programma il servizio", "Workspace -> WorkOrder -> Programma"));
                            break;
                        case WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled:
                            var hasShift = State.Shifts.Any(s => s.ServiceEntries.Any(se => se.ServiceId == wo.Id));
                            if (!hasShift)
                                steps.Add(new(Icons.Material.Filled.Group, Color.Warning, $"Crea Mission + Shift per {svcLabel}", "Scegli giorno, furgone e crea la mission nel Planning", "Workspace -> Planning"));
                            else
                                steps.Add(new(Icons.Material.Filled.PlayArrow, Color.Success, $"Avvia Shift per {svcLabel}", "Avvia l'intervento — il servizio passa in esecuzione", "Workspace -> Shift -> Avvia"));
                            break;
                        case WeTacoo.Domain.Operational.Enums.WorkOrderStatus.InExecution:
                            steps.Add(new(Icons.Material.Filled.Build, Color.Warning, $"{svcLabel} in esecuzione", "Simula l'esecuzione e completa lo shift", "Workspace -> Shift -> Simula + Completa"));
                            break;
                        case WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Paused:
                            steps.Add(new(Icons.Material.Filled.Warning, Color.Error, $"{svcLabel} in pausa", "Intervento Commercial richiesto — risolvi il problema", "Workspace -> WorkOrder"));
                            break;
                        case WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToVerify:
                            steps.Add(new(Icons.Material.Filled.Verified, Color.Success, $"Verifica {svcLabel}", "Verifica i dati post-esecuzione e concludi il servizio", "Workspace -> WorkOrder -> Verifica e concludi"));
                            break;
                    }
                }
            }
        }

        if (steps.Count == 0 && deals.Any(d => d.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Concluded))
            steps.Add(new(Icons.Material.Filled.Celebration, Color.Success, "Tutto completato!", "Tutti i servizi di questo cliente sono conclusi", null));

        return steps;
    }

    // ══════════════════════════════════════════════════════════════
    // PLANNING HELPERS
    // ══════════════════════════════════════════════════════════════
    private List<WeTacoo.Domain.Operational.WorkOrder> GetScheduledUnassignedWOs()
    {
        var leadWos = GetLeadWorkOrders().Where(w =>
            w.Status is WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule
                or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled
        );
        // WO operativi (Type = Operational) senza lead — sempre visibili per la pianificazione
        var opsWos = State.WorkOrders.Where(w =>
            w.Type == WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational
            && w.Status is WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule
                or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled
        );
        return leadWos.Concat(opsWos).Distinct().ToList();
    }

    private bool HasAnyOpsWoToPlan()
        => State.WorkOrders.Any(w => w.Type == WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational
            && w.Status is WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule
                or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled);

    private List<WeTacoo.Domain.Operational.WorkOrder> GetWOsForDate(List<WeTacoo.Domain.Operational.WorkOrder> wos, DateTime? date)
        => wos.Where(w => w.ScheduledDate?.Date == date?.Date || w.ScheduledDate == null).ToList();

    private void CreateWorkspacePlanning()
    {
        if (_missionDate == null) return;
        if (State.Plannings.Any(p => p.Date.Date == _missionDate?.Date)) { Snackbar.Add("Planning esiste gia'", Severity.Warning); return; }
        var planning = new WeTacoo.Domain.Operational.Planning { Date = _missionDate.Value.Date };
        foreach (var op in State.Operators)
            planning.Resources.Add(new WeTacoo.Domain.Operational.Entities.Resource { ResourceType = "operator", SourceId = op.Id, AreaId = op.AreaId });
        foreach (var v in State.Vehicles)
            planning.Resources.Add(new WeTacoo.Domain.Operational.Entities.Resource { ResourceType = "vehicle", SourceId = v.Id });
        // Team automatico casuale con primi 2 operatori disponibili
        var autoTeamOps = State.Operators.Take(2).Select(o => o.Id).ToList();
        planning.Teams.Add(new WeTacoo.Domain.Operational.Entities.PlanningTeam { OperatorIds = autoTeamOps });
        State.Plannings.Add(planning);
        Snackbar.Add($"Planning creato per {planning.Date:dd/MM/yyyy} con team automatico", Severity.Success);
        State.NotifyStateChanged();
    }

    private void CreateTeamForPlanning(WeTacoo.Domain.Operational.Planning planning)
    {
        if (_newTeamOperatorIds.Count == 0) { Snackbar.Add("Seleziona almeno un operatore", Severity.Warning); return; }
        var team = new WeTacoo.Domain.Operational.Entities.PlanningTeam { OperatorIds = _newTeamOperatorIds.ToList() };
        planning.Teams.Add(team);
        _selectedTeamId = team.Id;
        _newTeamOperatorIds.Clear();
        _showNewTeamForm = false;
        Snackbar.Add($"Team creato con {team.OperatorIds.Count} operatori — selezionato per le nuove Mission", Severity.Success);
        State.NotifyStateChanged();
    }

    private List<DateTime> GetPlanningAvailableDates()
    {
        // Dates from slots + dates from scheduled WorkOrders + next 14 days
        var dates = new HashSet<DateTime>();
        foreach (var slot in State.Slots.Where(s => s.CanBook(1)))
            dates.Add(slot.Date.Date);
        foreach (var wo in State.WorkOrders.Where(w => w.ScheduledDate != null))
            dates.Add(wo.ScheduledDate!.Value.Date);
        for (int i = 0; i < 14; i++)
            dates.Add(DateTime.Today.AddDays(i));
        return dates.Where(d => d >= DateTime.Today).OrderBy(d => d).ToList();
    }

    // ══════════════════════════════════════════════════════════════
    // HELPERS
    // ══════════════════════════════════════════════════════════════
    private List<WeTacoo.Domain.Commercial.Deal> GetLeadDeals()
        => State.Deals.Where(d => d.LeadId == _selectedLeadId).ToList();

    private List<WeTacoo.Domain.Operational.WorkOrder> GetLeadWorkOrders()
    {
        if (string.IsNullOrEmpty(_selectedLeadId)) return [];
        // Legame canonico: Lead -> Deal -> Quotation -> ServiceBooked -> WorkOrderId
        var svcWoIds = State.Deals.Where(d => d.LeadId == _selectedLeadId)
            .SelectMany(d => d.Quotations).SelectMany(q => q.Services)
            .Select(s => s.WorkOrderId).Where(id => id != null).Cast<string>().ToHashSet();
        // Legame alternativo (solo per scenari che popolano esplicitamente Commercial): wo.Commercial.LeadId
        return State.WorkOrders
            .Where(wo => svcWoIds.Contains(wo.Id) || wo.Commercial?.LeadId == _selectedLeadId)
            .ToList();
    }

    private List<WeTacoo.Domain.Execution.Shift> GetLeadShifts()
        => State.Shifts.Where(s => s.ServiceEntries.Any(se => se.LeadId == _selectedLeadId)).ToList();

    private List<WeTacoo.Domain.Financial.Payment> GetLeadPayments()
    {
        var dealIds = GetLeadDeals().Select(d => d.Id).ToHashSet();
        return State.Payments.Where(p => dealIds.Contains(p.DealId)).ToList();
    }

    private List<WeTacoo.Domain.Execution.PhysicalObject> GetLeadObjects()
        => State.Objects.Where(o => o.LeadId == _selectedLeadId).ToList();

    private List<WeTacoo.Domain.Events.IDomainEvent> GetLeadEvents()
    {
        if (string.IsNullOrEmpty(_selectedLeadId)) return [];
        var dealIds = GetLeadDeals().Select(d => d.Id).ToHashSet();
        var woIds = GetLeadWorkOrders().Select(w => w.Id).ToHashSet();
        var shiftIds = GetLeadShifts().Select(s => s.Id).ToHashSet();

        return State.EventLog
            .Where(e =>
                e.Description.Contains(_selectedLeadId) ||
                dealIds.Any(id => e.Description.Contains(id)) ||
                woIds.Any(id => e.Description.Contains(id)) ||
                shiftIds.Any(id => e.Description.Contains(id)))
            .Take(50)
            .ToList();
    }

    // ── Color helpers ──
    private Color StatusColor(string s) => s switch
    {
        "Active" or "Converted" or "Completed" or "Finalized" => Color.Success,
        "Concluded" or "Cancelled" or "NotConverted" or "Archived" => Color.Error,
        "ToQualify" or "ToVerify" or "ToAdjust" or "ToConvert" => Color.Warning,
        "InNegotiation" or "InProgress" or "Qualified" => Color.Info,
        _ => Color.Default
    };

    private Color WOStatusColor(string s) => s switch
    {
        "Concluded" or "Completed" => Color.Success,
        "Cancelled" => Color.Error,
        "InExecution" or "Paused" => Color.Warning,
        "Scheduled" => Color.Info,
        "ToVerify" => Color.Secondary,
        "ToSchedule" => Color.Default,
        _ => Color.Default
    };

