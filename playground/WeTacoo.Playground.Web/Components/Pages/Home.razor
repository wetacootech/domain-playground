    // SHIFT ACTIONS
    // ══════════════════════════════════════════════════════════════
    private void AvviaShift(WeTacoo.Domain.Execution.Shift shift)
    {
        if (shift.Status != "Created") return;
        shift.Start();
        // WO: Programmato -> InEsecuzione (via OperationStartedEvent in PlaygroundState.ProcessEvent)
        foreach (var se in shift.ServiceEntries)
        {
            State.PublishEvent(new WeTacoo.Domain.Events.OperationStartedEvent(shift.Id, se.ServiceId));
        }
        Snackbar.Add("Shift avviato — servizi in esecuzione", Severity.Success);
        State.NotifyStateChanged();
    }

    private void SimulaEsecuzione(WeTacoo.Domain.Execution.Shift shift)
    {
        if (shift.Status != "InProgress") return;

        var pickedCount = 0;
        var loadedCount = 0;

        foreach (var se in shift.ServiceEntries)
        {
            if (se.Completed) continue;

            // DDD5 review 2026-04-14: SE senza Start; l'in-progress vive sullo Shift InCorso

            bool isRitiro = se.Type is WeTacoo.Domain.Execution.Enums.ServiceEntryType.Ritiro
                            or WeTacoo.Domain.Execution.Enums.ServiceEntryType.TraslocoRitiro
                            or WeTacoo.Domain.Execution.Enums.ServiceEntryType.RitiroTraslocoDeposito;

            if (isRitiro)
            {
                // Ritiro: censimento — crea 3-5 nuovi PhysicalObject, PickUp → OnVehicle
                var objectCount = _rng.Next(3, 6);
                var entryObjectIds = new List<string>();
                for (int i = 1; i <= objectCount; i++)
                {
                    var name = $"{_objectNames[_rng.Next(_objectNames.Length)]} {i}";
                    var volume = Math.Round((decimal)(_rng.NextDouble() * 1.7 + 0.3), 1);
                    var obj = new WeTacoo.Domain.Execution.PhysicalObject
                    {
                        Name = name, Volume = volume, DealId = se.DealId, LeadId = se.LeadId
                    };
                    State.Objects.Add(obj);

                    var oldStatus = obj.Status.ToString();
                    obj.PickUp(shift.MissionId);
                    State.PublishEvent(new WeTacoo.Domain.Events.ObjectStateChangedEvent(obj.Id, oldStatus, obj.Status.ToString(), "PickUp"));

                    oldStatus = obj.Status.ToString();
                    obj.LoadOnVehicle(shift.MissionId);
                    State.PublishEvent(new WeTacoo.Domain.Events.ObjectStateChangedEvent(obj.Id, oldStatus, obj.Status.ToString(), "LoadOnVehicle"));

                    entryObjectIds.Add(obj.Id);
                    pickedCount++;
                }
                shift.AddTask(WeTacoo.Domain.Execution.Enums.TaskType.Censimento, se.Id, entryObjectIds);
            }
            else
            {
                // Consegna/Smaltimento: NON creare oggetti — recupera quelli preselezionati nel ServiceBooked e caricali sul veicolo
                var svc = FindServiceBookedForWoId(se.ServiceId);
                var selectedIds = svc?.SelectedObjectIds ?? [];
                var loadedForThisSe = new List<string>();

                foreach (var objId in selectedIds)
                {
                    var obj = State.Objects.FirstOrDefault(o => o.Id == objId);
                    if (obj == null) continue;
                    if (obj.Status == WeTacoo.Domain.Execution.Enums.ObjectStatus.OnWarehouse)
                    {
                        var oldStatus = obj.Status.ToString();
                        obj.LoadOnVehicle(shift.MissionId);
                        State.PublishEvent(new WeTacoo.Domain.Events.ObjectStateChangedEvent(obj.Id, oldStatus, obj.Status.ToString(), "LoadFromWarehouse"));
                        loadedCount++;
                    }
                    loadedForThisSe.Add(obj.Id);
                }

                var taskType = se.Type switch
                {
                    WeTacoo.Domain.Execution.Enums.ServiceEntryType.Smaltimento => WeTacoo.Domain.Execution.Enums.TaskType.Uscita,
                    _ => WeTacoo.Domain.Execution.Enums.TaskType.Scarico
                };
                shift.AddTask(taskType, se.Id, loadedForThisSe);
            }
        }

        var msg = pickedCount > 0 && loadedCount > 0
            ? $"Esecuzione simulata: {pickedCount} oggetti censiti, {loadedCount} caricati dal deposito — premi Completa su ciascuna"
            : pickedCount > 0
                ? $"Esecuzione simulata: {pickedCount} oggetti censiti — premi Completa su ciascuna"
                : $"Esecuzione simulata: {loadedCount} oggetti caricati dal deposito — premi Completa su ciascuna";
        Snackbar.Add(msg, Severity.Success);
        State.NotifyStateChanged();
    }

    private void CreateOperationalWo()
    {
        if (_opsWoAreaId == null && State.Areas.Count > 0) _opsWoAreaId = State.Areas[0].Id;
        var wo = new WeTacoo.Domain.Operational.WorkOrder
        {
            Type = WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational,
            ServiceType = new WeTacoo.Domain.Operational.ValueObjects.ServiceTypeVO(_opsWoServiceType, false, false, _opsWoAreaId),
            ServiceAddress = _opsWoAddress,
            EstimatedVolume = _opsWoVolume,
            Operational = new WeTacoo.Domain.Operational.ValueObjects.OperationalDataVO(null, _opsWoServiceType.ToString(), _opsWoAddress)
        };
        // WO operativo: salta InCompletamento, parte da DaProgrammare
        wo.ServizioPronto("Ops");
        State.WorkOrders.Add(wo);
        State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderCreatedEvent(wo.Id, wo.Type.ToString(), _opsWoServiceType.ToString()));
        Snackbar.Add($"WO operativo {_opsWoServiceType} creato — stato: {wo.Status}", Severity.Success);
        _showOpsWoForm = false;
        _opsWoAddress = "";
        State.NotifyStateChanged();
    }

    private void AddExtraTask(WeTacoo.Domain.Execution.Shift shift)
