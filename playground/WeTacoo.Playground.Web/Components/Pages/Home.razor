    private void CreateDealForLead()
    {
        if (string.IsNullOrEmpty(_selectedLeadId)) return;
        var lead = State.Leads.First(l => l.Id == _selectedLeadId);

        // Tipo Deal e' derivato: diventa Recurring quando una Quotation con DraftPlan viene accettata
        // Area non e' piu' richiesta a livello Deal (review 2026-04-16): vive sui singoli servizi e sull'ActivePlan.
        var deal = new WeTacoo.Domain.Commercial.Deal { LeadId = lead.Id };
        State.Deals.Add(deal);
        lead.AddDeal(deal.Id);
        State.PublishEvent(new WeTacoo.Domain.Events.DealCreatedEvent(deal.Id, lead.Id));

        var mkt = State.MarketingClients.FirstOrDefault(m => m.CommercialLeadId == lead.Id);
        mkt?.AddDeal(deal.Id);

        Snackbar.Add($"Deal creato — tipo determinato alla finalizzazione della Quotation", Severity.Success);
        State.NotifyStateChanged();
    }

    private void QualifyDeal(WeTacoo.Domain.Commercial.Deal deal)
    {
        deal.Qualify();
        State.PublishEvent(new WeTacoo.Domain.Events.DealQualifiedEvent(deal.Id));
        var mkt = State.MarketingClients.FirstOrDefault(m => m.CommercialLeadId == deal.LeadId);
        mkt?.AdvanceFunnel("Qualified");
        Snackbar.Add($"Deal qualificato", Severity.Success);
        State.NotifyStateChanged();
    }

    private void DiscardDeal(WeTacoo.Domain.Commercial.Deal deal)
    {
        deal.Discard();
        State.PublishEvent(new WeTacoo.Domain.Events.DealDiscardedEvent(deal.Id));
        var lead = State.Leads.FirstOrDefault(l => l.Id == deal.LeadId);
        lead?.RecalculateStatus(State.Deals.Where(d => d.LeadId == lead.Id).Select(d => d.Status));
        Snackbar.Add($"Deal scartato", Severity.Warning);
        State.NotifyStateChanged();
    }

