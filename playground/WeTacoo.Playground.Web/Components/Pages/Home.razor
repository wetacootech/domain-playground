    // ── Stato draft richiesta sopralluogo (DDD5 §4.8 review 2026-04-17) ──
    private string? _inspectionDraftSvcId;
    private string? _inspectionDraftSlotId;

    /// Conferma la richiesta sopralluogo. La data arriva dallo Slot selezionato (stesso pattern degli altri ServiceBooked).
    /// Crea: (1) Questionnaire template, (2) WorkOrder di Tipo Sopralluogo con QuestionnaireId.
    /// Il ServiceBooked passa in WaitingInspection e porta InspectionId = WO.Id.
    /// Il completamento NON e' manuale: avviene a fine Shift via OperationCompletedEvent (skip ToVerify).
    private void ConfirmRichiediSopralluogo(WeTacoo.Domain.Commercial.Entities.ServiceBooked forService)
    {
        var slot = !string.IsNullOrEmpty(_inspectionDraftSlotId)
            ? State.Slots.FirstOrDefault(s => s.Id == _inspectionDraftSlotId)
            : null;
        if (slot == null)
        {
            Snackbar.Add("Seleziona uno slot per il sopralluogo", Severity.Warning);
            return;
        }

        var deal = State.Deals.FirstOrDefault(d => d.Quotations.Any(q => q.Services.Any(s => s.Id == forService.Id)));
        var lead = deal != null ? State.Leads.FirstOrDefault(l => l.Id == deal.LeadId) : null;

        var questionnaire = new WeTacoo.Domain.Commercial.Questionnaire { Origin = "Sopralluogo" };
        questionnaire.Questions.Add(new WeTacoo.Domain.Commercial.Question { Data = new WeTacoo.Domain.Commercial.QuestionAnswer("Volume totale effettivo?", "number", null, "all") });
        questionnaire.Questions.Add(new WeTacoo.Domain.Commercial.Question { Data = new WeTacoo.Domain.Commercial.QuestionAnswer("Accessibilita' del sito?", "string", null, "all") });
        State.Questionnaires.Add(questionnaire);

        var wo = new WeTacoo.Domain.Operational.WorkOrder
        {
            Type = WeTacoo.Domain.Operational.Enums.WorkOrderType.Sopralluogo,
            ServiceBookedId = forService.Id,
            ServiceType = new WeTacoo.Domain.Operational.ValueObjects.ServiceTypeVO(
                WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Sopralluogo,
                IsPartial: false, IsAutonomous: false, AreaId: deal?.AreaId),
            Commercial = lead != null
                ? new WeTacoo.Domain.Operational.ValueObjects.CommercialData(lead.Id, questionnaire.Id, $"Sopralluogo propedeutico al {forService.Type}", [], false)
                : null,
            ServiceAddress = forService.ServiceAddress?.ZipCode,
            ContactName = lead != null ? $"{lead.Personal.FirstName} {lead.Personal.LastName}" : null,
            ScheduledDate = slot.Date,
            ScheduledSlot = slot.Id,
            Notes = $"Sopralluogo propedeutico al {forService.Type} (ServiceBooked {forService.Id.Substring(0, Math.Min(6, forService.Id.Length))})"
        };
        State.WorkOrders.Add(wo);
        slot.Book(1);

        forService.RichiediSopralluogo(wo.Id, questionnaire.Id);

        State.EventLog.Add(new WeTacoo.Domain.Events.SopralluogoRichiestoEvent(forService.Id, wo.Id, questionnaire.Id, forService.ServiceAddress?.ZipCode, $"Sopralluogo propedeutico al {forService.Type} — {slot.Date:dd/MM}"));
        State.EventLog.Add(new WeTacoo.Domain.Events.WorkOrderCreatedEvent(wo.Id, "Sopralluogo", "Sopralluogo"));
        wo.ServizioPronto("Commercial");
        State.EventLog.Add(new WeTacoo.Domain.Events.WorkOrderStatusChangedEvent(wo.Id, "Completing", "ToSchedule", "Servizio pronto"));

        Snackbar.Add($"Sopralluogo richiesto per {forService.Type} — WO {wo.Id.Substring(0, 6)} programmato il {slot.Date:dd/MM}", Severity.Info);

        _inspectionDraftSvcId = null;
        _inspectionDraftSlotId = null;
        State.NotifyStateChanged();
    }

    /// Toggle pairing bidirezionale tra due ServiceBooked (Ritiro ↔ Consegna) nella stessa Quotation.
    private void TogglePairing(WeTacoo.Domain.Commercial.Entities.ServiceBooked a, WeTacoo.Domain.Commercial.Entities.ServiceBooked b)
    {
        if (a.MovingIds.Contains(b.Id))
        {
            a.MovingIds.Remove(b.Id);
            b.MovingIds.Remove(a.Id);
        }
        else
        {
            a.MovingIds.Add(b.Id);
            b.MovingIds.Add(a.Id);
        }
        StateHasChanged();
    }

