    private void CreateQuotation(WeTacoo.Domain.Commercial.Deal deal)
    {
        // Assign selected objects to delivery/disposal services
        if (_selectedObjectIds.Count > 0)
        {
            var outboundServices = _quotationServices.Where(s =>
                s.Type is WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Consegna
                    or WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Smaltimento).ToList();
            if (outboundServices.Count == 1)
            {
                outboundServices[0].SelectedObjectIds = [.._selectedObjectIds];
            }
            else if (outboundServices.Count > 1)
            {
                // Distribute evenly for now, user can adjust
                var ids = _selectedObjectIds.ToList();
                var perService = ids.Count / outboundServices.Count;
                for (int i = 0; i < outboundServices.Count; i++)
                {
                    var take = i < outboundServices.Count - 1 ? perService : ids.Count;
                    outboundServices[i].SelectedObjectIds = ids.Take(take).ToList();
                    ids = ids.Skip(take).ToList();
                }
            }
            // Reserve objects
            foreach (var objId in _selectedObjectIds)
            {
                var obj = State.Objects.FirstOrDefault(o => o.Id == objId);
                if (obj != null) obj.ReservedByQuotationId = "pending";
            }
        }

        var quotation = new WeTacoo.Domain.Commercial.Entities.Quotation
        {
            DealId = deal.Id,
            IsInitial = deal.Quotations.Count == 0,
            Products = [.._quotationProducts],
            Services = [.._quotationServices],
        };

        // DraftPlan opzionale: se la checkbox "Includi piano" e' attiva → aggiunge il piano → Deal diventa Recurring all'accettazione
        if (deal.ActivePlan == null && _includePlan && !string.IsNullOrWhiteSpace(_newQuotPlanDesc))
        {
            quotation.DraftPlans.Add(new WeTacoo.Domain.Commercial.Entities.DraftPlan
            {
                Description = _newQuotPlanDesc,
                MonthlyFee = _newQuotPlanFee,
                EstimatedM3 = _newQuotPlanM3,
                AreaId = deal.AreaId
            });
        }

        deal.Quotations.Add(quotation);

        if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Qualified)
            deal.EnterNegotiation();

        _showNewQuotation = false;
        _quotationProducts = [];
        _quotationServices = [];
        _selectedObjectIds = [];
        Snackbar.Add($"Quotation creata con {quotation.Services.Count} servizi, {quotation.Products.Count} prodotti — Totale: {quotation.TotalPrice:C}", Severity.Success);
        State.NotifyStateChanged();
    }

    // ══════════════════════════════════════════════════════════════
    // ACCEPT QUOTATION — Cross-BC Cascade
    // ══════════════════════════════════════════════════════════════
    /// <summary>Finalizza la quotation e scatena la cascade di accettazione (Questionnaire + WorkOrder + Payment + cascate stati).</summary>
    private void FinalizeAndAccept(WeTacoo.Domain.Commercial.Deal deal, WeTacoo.Domain.Commercial.Entities.Quotation q)
    {
        q.Finalize();
        AcceptQuotation(deal, q);
    }

    private void AcceptQuotation(WeTacoo.Domain.Commercial.Deal deal, WeTacoo.Domain.Commercial.Entities.Quotation acceptedQuotation)
    {
        try
        {
            var lead = State.Leads.First(l => l.Id == deal.LeadId);

            // 1. Finalize this quotation
            acceptedQuotation.Finalize();

            // 1a. Marca IsInitial sulla prima Quotation accettata del Deal
            bool hasAlreadyInitial = deal.Quotations.Any(q => q.Id != acceptedQuotation.Id && q.IsInitial);
            if (!hasAlreadyInitial)
                acceptedQuotation.IsInitial = true;

            // 1b. Se l'accettata ha un DraftPlan, archivia tutte le altre Quotation con DraftPlan non-finalizzate
            //     (alternative di piano scartate). Le Quotation senza piano restano come servizi aggiuntivi.
            if (acceptedQuotation.DraftPlans.Count > 0)
            {
                foreach (var other in deal.Quotations.Where(q => q.Id != acceptedQuotation.Id
                    && q.DraftPlans.Count > 0
                    && q.Status is WeTacoo.Domain.Commercial.Enums.QuotationStatus.Draft
                                or WeTacoo.Domain.Commercial.Enums.QuotationStatus.InProgress))
                    other.Archive();
            }

            // 2. If deal not yet converted, do the full conversion flow
            bool isFirstAccept = deal.Status is WeTacoo.Domain.Commercial.Enums.DealStatus.ToQualify
                or WeTacoo.Domain.Commercial.Enums.DealStatus.Qualified
                or WeTacoo.Domain.Commercial.Enums.DealStatus.InNegotiation;

            if (isFirstAccept)
            {
                // Deal.Type e' derivato: diventa Recurring automaticamente se la Quotation accettata ha un DraftPlan.

                if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.ToQualify)
                {
                    deal.Qualify();
                    State.PublishEvent(new WeTacoo.Domain.Events.DealQualifiedEvent(deal.Id));
                }
                if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Qualified)
                    deal.EnterNegotiation();
                if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.InNegotiation)
                    deal.Convert();

                lead.MarkConverted();
                State.PublishEvent(new WeTacoo.Domain.Events.DealConvertedEvent(deal.Id, lead.Id));

                // Create ActivePlan if Recurring+DraftPlan (Deal stays Converted — Active when services complete)
                if (acceptedQuotation.DraftPlans.Count > 0)
                    deal.CreatePlan(acceptedQuotation, acceptedQuotation.DraftPlans.First());
            }

            // Trasloco pairing via MovingIds (DDD5 §2.2e, review 2026-04-16):
            // se OneOff con Ritiro + Consegna appaiamo tutti i Ritiri con tutte le Consegne della stessa Quotation.
            if (deal.Type == WeTacoo.Domain.Commercial.Enums.DealType.OneOff)
            {
                var ritiri = acceptedQuotation.Services.Where(s => s.Type == WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Ritiro).ToList();
                var consegne = acceptedQuotation.Services.Where(s => s.Type == WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Consegna).ToList();
                if (ritiri.Count > 0 && consegne.Count > 0)
                {
                    foreach (var r in ritiri)
                        foreach (var c in consegne)
                        {
                            if (!r.MovingIds.Contains(c.Id)) r.MovingIds.Add(c.Id);
                            if (!c.MovingIds.Contains(r.Id)) c.MovingIds.Add(r.Id);
                        }
                }
            }

            // HasPlan snapshot per il WO (review 2026-04-16)
            bool hasPlan = deal.ActivePlan != null || acceptedQuotation.DraftPlans.Count > 0;

            // 3. Emit QuotationAcceptedEvent (always, even for additional quotations)
            State.PublishEvent(new WeTacoo.Domain.Events.QuotationAcceptedEvent(
                acceptedQuotation.Id, deal.Id, lead.Id,
                deal.Type == WeTacoo.Domain.Commercial.Enums.DealType.Recurring));

            // 4. Create Questionnaire + WorkOrder for each ServiceBooked
            foreach (var svc in acceptedQuotation.Services)
            {
                // ServiceBooked: DaAccettare -> DaCompletare
                svc.AccettaServizio();

                // Create Questionnaire for the service (uses QuestionTemplates from seed)
                var questionnaire = new WeTacoo.Domain.Commercial.Questionnaire { Origin = "Quotation" };
                foreach (var qt in State.QuestionTemplates.Where(q => q.IsActive))
                {
                    questionnaire.Questions.Add(new WeTacoo.Domain.Commercial.Question
                    {
                        QuestionTemplateId = qt.Id,
                        Data = new WeTacoo.Domain.Commercial.QuestionAnswer(qt.Question, qt.QuestionType, null, qt.Visibility)
                    });
                }
                State.Questionnaires.Add(questionnaire);
                svc.QuestionnaireId = questionnaire.Id;

                // Auto-verifica: nessuna domanda attiva
                bool autoReady = !State.QuestionTemplates.Any(q => q.IsActive);
                if (autoReady)
                {
                    questionnaire.IsVerified = true;
                    svc.SegnaComePronto();
                }

                // Create WorkOrder — linked directly via ServiceBookedId
                var wo = new WeTacoo.Domain.Operational.WorkOrder
                {
                    Type = WeTacoo.Domain.Operational.Enums.WorkOrderType.Commercial,
                    ServiceBookedId = svc.Id,
                    ServiceType = new WeTacoo.Domain.Operational.ValueObjects.ServiceTypeVO(
                        svc.Type switch
                        {
                            WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Ritiro => WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Ritiro,
                            WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Consegna => WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Consegna,
                            WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Smaltimento => WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Smaltimento,
                            _ => WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Ritiro
                        },
                        IsPartial: false,
                        IsAutonomous: svc.IsAutonomous,
                        AreaId: deal.AreaId),
                    ServiceAddress = svc.ServiceAddress?.ZipCode,
                    ContactName = $"{lead.Personal.FirstName} {lead.Personal.LastName}",
                    EstimatedVolume = deal.ActivePlan?.CurrentM3 ?? 0,
                    ScheduledDate = svc.ScheduledDate,
                    ScheduledSlot = svc.ScheduledSlot,
                    Commercial = new WeTacoo.Domain.Operational.ValueObjects.CommercialData(lead.Id, questionnaire.Id, null, [.. svc.MovingIds], hasPlan),
                };
                State.WorkOrders.Add(wo);
                svc.WorkOrderId = wo.Id;

                State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderCreatedEvent(wo.Id, wo.Type.ToString(), svc.Type.ToString()));

                // If service is Pronto, publish ServizioProntoEvent -> WO: InCompletamento -> DaProgrammare
                if (svc.Status == WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.Ready)
                {
                    State.PublishEvent(new WeTacoo.Domain.Events.ServizioProntoEvent(svc.Id, wo.Id));
                }
            }

            // 5. Create FinancialClient + Payment
            var finClient = State.FinancialClients.FirstOrDefault(c => c.CommercialLeadId == lead.Id);
            if (finClient == null)
            {
                finClient = new WeTacoo.Domain.Financial.FinancialClient
                {
                    CommercialLeadId = lead.Id,
                    BillingName = $"{lead.Personal.FirstName} {lead.Personal.LastName}"
                };
                State.FinancialClients.Add(finClient);
                lead.FinancialClientId = finClient.Id;
            }
            var payment = new WeTacoo.Domain.Financial.Payment
            {
                ClientId = finClient.Id,
                DealId = deal.Id,
                QuotationId = acceptedQuotation.Id,
                PaymentType = deal.Type == WeTacoo.Domain.Commercial.Enums.DealType.Recurring ? "Recurring" : "OneOff"
            };
            foreach (var p in acceptedQuotation.Products)
            {
                payment.Products.Add(new WeTacoo.Domain.Financial.SimplifiedProduct
                {
                    Name = p.Name, Description = p.Description, Price = p.Price
                });
            }
            // Auto-add first charge based on total
            if (payment.TotalAmount > 0)
                payment.AddCharge(payment.TotalAmount);

            State.Payments.Add(payment);
            State.PublishEvent(new WeTacoo.Domain.Events.PaymentCreatedEvent(payment.Id, deal.Id));

            // 6. Update MarketingClient funnel
            var mkt = State.MarketingClients.FirstOrDefault(m => m.CommercialLeadId == lead.Id);
            mkt?.AdvanceFunnel("Converted");

            Snackbar.Add($"Quotation accettata! Deal convertito, {acceptedQuotation.Services.Count} WO + Payment creati.", Severity.Success);
            State.NotifyStateChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    // ══════════════════════════════════════════════════════════════
    // WORKORDER ACTIONS (direct state machine on WorkOrder)
    // ══════════════════════════════════════════════════════════════

    /// <summary>
    /// Verifica WorkOrder: DaVerificare -> Concluso.
    /// Pubblica ServizioCompletatoEvent che triggera la catena cross-BC in PlaygroundState.ProcessEvent:
    /// ServiceBooked Completato -> Quotation Completato/DaAdeguare -> Deal Attivo/Concluso.
    /// </summary>
    private void ConcludeWO(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        var oldStatus = wo.Status.ToString();
        wo.VerificaEConcludi("Ops");
        State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderStatusChangedEvent(wo.Id, oldStatus, wo.Status.ToString(), "Verificato e concluso"));

        // Publish ServizioCompletatoEvent to trigger cross-BC cascade
        var hasDiff = wo.ActualVolume != wo.EstimatedVolume && wo.ActualVolume > 0;
        State.PublishEvent(new WeTacoo.Domain.Events.ServizioCompletatoEvent(
            wo.Id, wo.ServiceBookedId, wo.ActualVolume, hasDiff, "Verifica completata"));

        Snackbar.Add("Servizio verificato e concluso", Severity.Success);
    }

    // ══════════════════════════════════════════════════════════════
    // CREATE / CONFIRM / DELETE MISSION (multi-WO, due step)
    // ══════════════════════════════════════════════════════════════

    /// <summary>Crea una Mission "non confermata" con i WO selezionati. Non crea Shift.</summary>
    private void CreateMissionForSelectedWos()
    {
        try
        {
            if (_missionDate == null) { Snackbar.Add("Seleziona un giorno", Severity.Warning); return; }
            if (_selectedNewMissionWoIds.Count == 0) { Snackbar.Add("Seleziona almeno un servizio", Severity.Warning); return; }

            var wos = State.WorkOrders.Where(w => _selectedNewMissionWoIds.Contains(w.Id)).ToList();
            if (wos.Any(w => w.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Completing))
            { Snackbar.Add("Alcuni WO sono 'In completamento' — completa prima il questionario", Severity.Warning); return; }

            var planning = State.Plannings.FirstOrDefault(p => p.Date.Date == _missionDate.Value.Date);
            if (planning == null) { Snackbar.Add("Crea prima il Planning per questo giorno", Severity.Warning); return; }

            // Team: selezionato o primo/automatico
            var team = !string.IsNullOrEmpty(_selectedTeamId)
                ? planning.Teams.FirstOrDefault(t => t.Id == _selectedTeamId)
                : planning.Teams.FirstOrDefault();
            if (team == null)
            {
                var operatorIds = State.Operators.Take(2).Select(o => o.Id).ToList();
                team = new WeTacoo.Domain.Operational.Entities.PlanningTeam { OperatorIds = operatorIds };
                planning.Teams.Add(team);
            }

            // Vehicles: multi-select con fallback
            var vehicleIds = _selectedVehicleIds.Count > 0
                ? _selectedVehicleIds.ToList()
                : (State.Vehicles.FirstOrDefault(v => v.Status == "Available") is { } fv ? new List<string> { fv.Id } : new List<string>());
            if (vehicleIds.Count == 0) { Snackbar.Add("Nessun veicolo disponibile", Severity.Warning); return; }

            var refs = wos.Select(w => new WeTacoo.Domain.Operational.Entities.ServiceRef(w.Id, _missionVolumePercent)).ToList();
            var mission = planning.AddMission(team.Id, refs, vehicleIds);
            mission.TimeSlot = string.IsNullOrWhiteSpace(_missionTimeSlot) ? "09:00-12:00" : _missionTimeSlot;

            _selectedNewMissionWoIds.Clear();
            Snackbar.Add($"Mission creata con {refs.Count} servizi — premi 'Conferma' per generare lo Shift", Severity.Success);
            State.NotifyStateChanged();
        }
        catch (Exception ex) { Snackbar.Add($"Errore: {ex.Message}", Severity.Error); }
    }

    /// <summary>Conferma la Mission: crea Shift + ServiceEntries + avanza WO a Programmato.</summary>
    private void ConfirmMissionShift(WeTacoo.Domain.Operational.Planning planning, WeTacoo.Domain.Operational.Entities.Mission mission)
    {
        try
        {
            if (mission.IsCancelled) return;
            if (State.Shifts.Any(s => s.MissionId == mission.Id)) { Snackbar.Add("Shift gia' creato per questa Mission", Severity.Warning); return; }

            var team = planning.Teams.FirstOrDefault(t => t.Id == mission.TeamId);
            var operatorIds = team?.OperatorIds ?? [];

            var shift = new WeTacoo.Domain.Execution.Shift
            {
                MissionId = mission.Id,
                Date = planning.Date,
                Mission = new WeTacoo.Domain.Execution.MissionData(operatorIds, mission.VehicleResourceIds.ToList(), [], mission.TimeSlot),
                Resources = new WeTacoo.Domain.Execution.ShiftResources(operatorIds, mission.VehicleResourceIds.ToList(), [])
            };

            foreach (var sr in mission.ServiceRefs)
            {
                var wo = State.WorkOrders.FirstOrDefault(w => w.Id == sr.ServiceId);
                if (wo == null) continue;

                string? dealId = null, leadId = wo.Commercial?.LeadId;
                WeTacoo.Domain.Execution.Entities.ClientData? clientData = null;
                if (leadId != null)
                {
                    var lead = State.Leads.FirstOrDefault(l => l.Id == leadId);
                    dealId = State.Deals.FirstOrDefault(d => d.LeadId == leadId)?.Id;
                    if (lead != null)
                        clientData = new WeTacoo.Domain.Execution.Entities.ClientData($"{lead.Personal.FirstName} {lead.Personal.LastName}", lead.Personal.Phone ?? "");
                }
                shift.AddServiceEntry(wo.Id, dealId, leadId, MapServiceEntryType(wo), clientData);

                if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule)
                {
                    var oldStatus = wo.Status.ToString();
                    wo.Programma("Ops");
                    State.PublishEvent(new WeTacoo.Domain.Events.WorkOrderStatusChangedEvent(wo.Id, oldStatus, wo.Status.ToString(), "Programmato via Mission"));
                }
            }

            State.Shifts.Add(shift);
            State.PublishEvent(new WeTacoo.Domain.Events.ShiftCreatedEvent(shift.Id, mission.Id));
            Snackbar.Add($"Mission confermata: Shift {shift.Id.Substring(0, 8)} creato con {shift.ServiceEntries.Count} servizi", Severity.Success);
            State.NotifyStateChanged();
        }
        catch (Exception ex) { Snackbar.Add($"Errore: {ex.Message}", Severity.Error); }
    }

    /// <summary>Elimina una Mission non ancora confermata (senza Shift).</summary>
    private void DeleteMission(WeTacoo.Domain.Operational.Planning planning, WeTacoo.Domain.Operational.Entities.Mission mission)
    {
        if (State.Shifts.Any(s => s.MissionId == mission.Id))
        { Snackbar.Add("Impossibile eliminare: Shift gia' creato", Severity.Warning); return; }
        planning.Missions.Remove(mission);
        Snackbar.Add($"Mission {mission.Id.Substring(0, 8)} eliminata", Severity.Info);
        State.NotifyStateChanged();
    }

    /// <summary>
    /// Deriva il tipo di ServiceEntry dal WorkOrder (DDD5 §2.1, review 2026-04-16).
    /// La logica combina ServiceType, MovingIds (pairing trasloco) e HasPlan (piano ricorrente).
    /// </summary>
    private static WeTacoo.Domain.Execution.Enums.ServiceEntryType MapServiceEntryType(WeTacoo.Domain.Operational.WorkOrder wo)
    {
        var svcType = wo.ServiceType;
        bool isTrasloco = wo.Commercial?.MovingIds.Count > 0;
        bool hasPlan = wo.Commercial?.HasPlan ?? false;
        return svcType.Type switch
        {
            WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Ritiro => isTrasloco
                ? (hasPlan ? WeTacoo.Domain.Execution.Enums.ServiceEntryType.RitiroTraslocoDeposito : WeTacoo.Domain.Execution.Enums.ServiceEntryType.TraslocoRitiro)
                : WeTacoo.Domain.Execution.Enums.ServiceEntryType.Ritiro,
            WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Consegna => isTrasloco
                ? (hasPlan ? WeTacoo.Domain.Execution.Enums.ServiceEntryType.ConsegnaTraslocoDeposito : WeTacoo.Domain.Execution.Enums.ServiceEntryType.TraslocoConsegna)
                : WeTacoo.Domain.Execution.Enums.ServiceEntryType.Consegna,
            WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Smaltimento => WeTacoo.Domain.Execution.Enums.ServiceEntryType.Smaltimento,
            WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Sopralluogo => WeTacoo.Domain.Execution.Enums.ServiceEntryType.Sopralluogo,
            _ => WeTacoo.Domain.Execution.Enums.ServiceEntryType.Ritiro
        };
    }

