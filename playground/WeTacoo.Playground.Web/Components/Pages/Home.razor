        <MudCard Class="mb-2 bc-financial-pane" Elevation="1">
            <MudCardContent>
                <div class="d-flex align-center gap-2 mb-1">
                    <MudText Typo="Typo.body2"><b>@payment.Id.Substring(0, Math.Min(8, payment.Id.Length))...</b></MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(payment.Status == WeTacoo.Domain.Financial.Enums.PaymentStatus.Paid ? Color.Success : Color.Warning)">@payment.Status</MudChip>
                    <MudSpacer />
                    <EntityActions Kind="Payment" Ids="@(new[] { payment.Id })" Entity="payment" OnChanged="StateHasChanged" />
                </div>
                @if (payment.Products.Count > 0)
                {
                    <MudText Typo="Typo.caption">@string.Join(", ", payment.Products.Select(p => $"{p.Name} ({p.Price:C})"))</MudText>
                }
                <MudText Typo="Typo.caption" Class="mt-1">Totale: @payment.TotalAmount.ToString("C") | Pagato: @payment.PaidAmount.ToString("C")</MudText>
                @if (payment.TotalAmount > 0)
                {
                    <MudProgressLinear Color="Color.Success" Value="@(payment.TotalAmount > 0 ? (double)(payment.PaidAmount / payment.TotalAmount * 100) : 0)" Class="my-1" />
                }
                @foreach (var charge in payment.Charges)
                {
                    var c = charge;
                    <div class="d-flex align-center gap-2 mt-1">
                        <MudChip T="string" Size="Size.Small" Color="@(c.Status == WeTacoo.Domain.Financial.Enums.ChargeStatus.Executed ? Color.Success : c.Status == WeTacoo.Domain.Financial.Enums.ChargeStatus.Failed ? Color.Error : Color.Warning)">@c.Status</MudChip>
