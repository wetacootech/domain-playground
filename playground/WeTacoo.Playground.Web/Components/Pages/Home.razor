@page "/"
@inject PlaygroundState State
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject EntityAdminService Admin
@implements IDisposable

<PageTitle>WeTacoo Workspace</PageTitle>

@* ══════════════════ TOP BAR: Quick Actions ══════════════════ *@
<MudPaper Class="pa-3 mb-4" Elevation="2">
    <MudText Typo="Typo.h5" Class="mb-2">Workspace</MudText>
    <div class="d-flex gap-2 flex-wrap">
        <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.SwapHoriz"
                   OnClick="@(() => _showOpsWoForm = !_showOpsWoForm)">Nuovo WO operativo</MudButton>
        <MudTooltip Text="Azzera tutto lo stato del playground (lead, deal, wo, mission, shift, object)">
            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="ResetAll">Reset Playground</MudButton>
        </MudTooltip>
    </div>

    @if (_showOpsWoForm)
    {
        <MudPaper Class="pa-3 mt-3" Outlined="true">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Nuovo WorkOrder operativo (Trasferimento / Trasbordo)</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">WO di tipo Operational — non legato a un servizio venduto. Tipicamente usato per trasferimenti inter-magazzino o trasbordi tra team.</MudText>
            <div class="d-flex gap-2 flex-wrap align-center">
                <MudSelect @bind-Value="_opsWoServiceType" T="WeTacoo.Domain.Operational.Enums.ServiceTypeEnum" Label="Tipo" Dense="true" Style="max-width:180px">
                    <MudSelectItem T="WeTacoo.Domain.Operational.Enums.ServiceTypeEnum" Value="WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Trasferimento">Trasferimento</MudSelectItem>
                    <MudSelectItem T="WeTacoo.Domain.Operational.Enums.ServiceTypeEnum" Value="WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Trasbordo">Trasbordo</MudSelectItem>
                </MudSelect>
                <MudSelect @bind-Value="_opsWoAreaId" T="string" Label="Area" Dense="true" Style="max-width:180px">
                    @foreach (var area in State.Areas)
                    { <MudSelectItem T="string" Value="@area.Id">@area.Name</MudSelectItem> }
                </MudSelect>
                <MudTextField @bind-Value="_opsWoAddress" Label="Indirizzo / Note" Dense="true" Style="max-width:240px" />
                <MudNumericField @bind-Value="_opsWoVolume" Label="Vol (m3)" Format="N1" Step="0.5m" Min="0m" Dense="true" Style="max-width:100px" />
                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                           OnClick="CreateOperationalWo">Crea</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Text"
                           OnClick="@(() => _showOpsWoForm = false)">Annulla</MudButton>
            </div>
        </MudPaper>
    }
</MudPaper>

<MudGrid>
    @* ══════════════════ LEFT COLUMN: Lead List ══════════════════ *@
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-3" Elevation="2" Style="max-height:85vh; overflow-y:auto;">
            <MudText Typo="Typo.h6" Class="mb-2">Clienti (@State.Leads.Count)</MudText>
            @if (State.Leads.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Nessun cliente.</MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true" Class="mb-2">
                    @foreach (var lead in State.Leads)
                    {
                        <MudListItem T="string" Dense="true" OnClick="@(() => SelectLead(lead.Id))"
                                     Style="@(_selectedLeadId == lead.Id ? "background-color: var(--mud-palette-primary-lighten); border-radius:4px;" : "")">
                            <div class="d-flex align-center gap-1" style="width:100%">
                                <MudText Typo="Typo.body2"><b>@lead.Personal.FirstName @lead.Personal.LastName</b></MudText>
                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(lead.Status.ToString())">@lead.Status</MudChip>
                                <MudSpacer />
                                <EntityActions Kind="Lead" Ids="@(new[] { lead.Id })" Entity="lead" OnChanged="StateHasChanged" />
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@lead.Personal.Email</MudText>
                        </MudListItem>
                    }
                </MudList>
            }

            @* Inline new lead form *@
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" FullWidth="true"
                       OnClick="@(() => _showInlineNewLead = !_showInlineNewLead)">Nuovo Lead Manuale</MudButton>
            @if (_showInlineNewLead)
            {
                <MudCard Class="mt-2 pa-2" Outlined="true">
                    <MudTextField @bind-Value="_inlineLeadFirstName" Label="Nome" Dense="true" Margin="Margin.Dense" />
                    <MudTextField @bind-Value="_inlineLeadLastName" Label="Cognome" Dense="true" Margin="Margin.Dense" />
                    <MudTextField @bind-Value="_inlineLeadEmail" Label="Email" Dense="true" Margin="Margin.Dense" />
                    <div class="d-flex gap-2 mt-2">
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   Disabled="@(string.IsNullOrWhiteSpace(_inlineLeadFirstName) || string.IsNullOrWhiteSpace(_inlineLeadEmail))"
                                   OnClick="CreateInlineLead">Crea</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _showInlineNewLead = false)">Annulla</MudButton>
                    </div>
                </MudCard>
            }

            @* ══════════════ PROSSIMI PASSI (sempre visibile sotto la lista clienti) ══════════════ *@
            <MudDivider Class="my-3" />
            <div class="d-flex align-center gap-1 mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Prossimi passi</MudText>
            </div>
            @{
                var selLead = !string.IsNullOrEmpty(_selectedLeadId) ? State.Leads.FirstOrDefault(l => l.Id == _selectedLeadId) : null;
                var guideSteps = selLead != null ? GetNextSteps(selLead) : new List<GuideStep>();
            }
            @if (selLead == null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Seleziona un cliente per vedere i suoi prossimi passi.</MudText>
            }
            else if (guideSteps.Count == 0)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">Nessuna azione pendente per @selLead.Personal.FirstName.</MudText>
            }
            else
            {
                <MudList T="string" Dense="true" DisablePadding="true">
                    @foreach (var step in guideSteps)
                    {
                        <MudListItem T="string" Dense="true" Icon="@step.Icon" IconColor="@step.Color">
                            <MudText Typo="Typo.caption"><b>@step.Action</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@step.Description</MudText>
                        </MudListItem>
                    }
                </MudList>
            }

            @* ══════════════ EVENTS (sotto i clienti, altezza limitata) ══════════════ *@
            <MudDivider Class="my-3" />
            <div class="d-flex align-center gap-1 mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Eventi</MudText>
            </div>
            <div style="max-height:280px; overflow-y:auto;">
                @if (string.IsNullOrEmpty(_selectedLeadId))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Seleziona un cliente per vedere gli eventi.</MudText>
                }
                else
                {
                    var leadEvents = GetLeadEvents();
                    @if (!leadEvents.Any())
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Nessun evento per questo cliente.</MudText>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-1">
                            @foreach (var evt in leadEvents)
                            {
                                <MudPaper Class="pa-1" Outlined="true">
                                    <div class="d-flex align-center gap-1">
                                        <MudChip T="string" Size="Size.Small" Color="@GetBCColor(evt.SourceBC)">@evt.SourceBC</MudChip>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@evt.OccurredAt.ToString("HH:mm:ss")</MudText>
                                    </div>
                                    <MudText Typo="Typo.caption"><b>@HumanDescription(evt)</b></MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-style:italic; font-size:0.7rem;">@evt.Description</MudText>
                                </MudPaper>
                            }
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </MudItem>

    @* ══════════════════ CENTER COLUMN: Flow for selected Lead ══════════════════ *@
    <MudItem xs="12" md="9">
        <MudPaper Class="pa-3" Elevation="2" Style="max-height:85vh; overflow-y:auto;">
            @if (string.IsNullOrEmpty(_selectedLeadId))
            {
                <MudAlert Severity="Severity.Info">Seleziona un cliente dalla lista o creane uno nuovo.</MudAlert>
                @if (HasAnyOpsWoToPlan())
                {
                    <MudAlert Severity="Severity.Warning" Class="mt-2">@State.WorkOrders.Count(w => w.Type == WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational && w.Status is WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled) WorkOrder operativi da pianificare — seleziona un qualunque cliente per accedere alla sezione Planning: i WO operativi compaiono sempre nella selezione Mission.</MudAlert>
                }
            }
            else
            {
                var selectedLead = State.Leads.FirstOrDefault(l => l.Id == _selectedLeadId);
                if (selectedLead == null)
                {
                    <MudAlert Severity="Severity.Warning">Lead non trovato.</MudAlert>
                }
                else
                {
                    @* ── 1. LEAD CARD ── *@
                    <MudCard Class="mb-3" Elevation="1">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Person" />
                                <MudText Typo="Typo.h6">@selectedLead.Personal.FirstName @selectedLead.Personal.LastName</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(selectedLead.Status.ToString())">@selectedLead.Status</MudChip>
                                @if (selectedLead.Customer.IsCustomer)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Cliente</MudChip>
                                }
                                <MudSpacer />
                                <EntityActions Kind="Lead" Ids="@(new[] { selectedLead.Id })" Entity="selectedLead" OnChanged="StateHasChanged" />
                            </div>
                            <MudText Typo="Typo.body2">Email: @selectedLead.Personal.Email | Tel: @(selectedLead.Personal.Phone ?? "-")</MudText>
                            <MudText Typo="Typo.body2">Deals: @selectedLead.DealIds.Count</MudText>

                            <MudDivider Class="my-2" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="CreateDealForLead">@(GetLeadDeals().Any() ? "Nuovo Deal" : "Crea Deal")</MudButton>
                        </MudCardContent>
                    </MudCard>

                    @* ── 2. DEALS ── *@
                    @if (GetLeadDeals().Any())
                    {
                        <MudText Typo="Typo.h6" Class="mb-2"><span class="bc-section-label commercial">Commercial</span><MudIcon Icon="@Icons.Material.Filled.Handshake" Size="Size.Small" /> Deal &amp; Quotation</MudText>
                    }
                    <MudExpansionPanels MultiExpansion="true" Class="mb-3">
                    @foreach (var deal in GetLeadDeals())
                    {
                        <MudExpansionPanel Class="bc-commercial-pane">
                            <TitleContent>
                                <div class="d-flex align-center gap-2" style="width:100%">
                                    <MudIcon Icon="@Icons.Material.Filled.Handshake" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1"><b>Deal @deal.Id</b></MudText>
                                    <MudChip T="string" Size="Size.Small">@deal.Type</MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(deal.Status.ToString())">@deal.Status</MudChip>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@deal.Quotations.Count quot</MudText>
                                    @if (deal.ActivePlan != null) { <MudChip T="string" Size="Size.Small" Color="Color.Success">Piano attivo</MudChip> }
                                    <MudSpacer />
                                    <EntityActions Kind="Deal" Ids="@(new[] { deal.Id })" Entity="deal" OnChanged="StateHasChanged" />
                                </div>
                            </TitleContent>
                            <ChildContent>

                                @* Contextual actions *@
                                <div class="d-flex gap-2 mb-2">
                                    @if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.ToQualify)
                                    {
                                        <MudButton Size="Size.Small" Color="Color.Info" Variant="Variant.Filled" OnClick="@(() => QualifyDeal(deal))">Qualifica Trattativa (Presales)</MudButton>
                                    }
                                    @if (deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.Qualified || deal.Status == WeTacoo.Domain.Commercial.Enums.DealStatus.InNegotiation)
                                    {
                                        <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined" OnClick="@(() => DiscardDeal(deal))">Scarta</MudButton>
                                    }
                                </div>

                                @* ── Interventi richiesti (WO In pausa di questo Deal) — decisione Commercial ── *@
                                @{
                                    var dealWosInPausa = deal.Quotations.SelectMany(q => q.Services)
                                        .Select(s => s.WorkOrderId != null ? State.WorkOrders.FirstOrDefault(w => w.Id == s.WorkOrderId) : null)
                                        .Where(w => w != null && w.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Paused)
                                        .Cast<WeTacoo.Domain.Operational.WorkOrder>()
                                        .ToList();
                                }
                                @if (dealWosInPausa.Count > 0)
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                                        <b>@dealWosInPausa.Count servizi in pausa — decisione richiesta</b>
                                    </MudAlert>
                                    @foreach (var pausedWo in dealWosInPausa)
                                    {
                                        var pwoId = pausedWo.Id;
                                        var pausedSvc = FindServiceForWo(pausedWo);
                                        <MudPaper Class="pa-2 mb-2" Outlined="true" Style="border-left: 3px solid var(--mud-palette-error);">
                                            <MudText Typo="Typo.caption"><b>Servizio @(pausedSvc?.Type): @pausedWo.ServiceAddress</b> — WO @pausedWo.Id.Substring(0, Math.Min(8, pausedWo.Id.Length))</MudText>
                                            <MudTextField T="string" Label="Nota per Ops"
                                                          Value="@GetInterventoNote(pwoId)"
                                                          ValueChanged="@((string v) => SetInterventoNote(pwoId, v))"
                                                          Margin="Margin.Dense" Style="max-width:420px" />
                                            <div class="d-flex gap-2 mt-1 flex-wrap">
                                                <MudButton Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                                                           OnClick="@(() => ResolveWoRiprogramma(pausedWo))">Riprogramma</MudButton>
                                                <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                                           OnClick="@(() => ResolveWoRiprendi(pausedWo))">Riprendi</MudButton>
                                                <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                           OnClick="@(() => ResolveWoChiudi(pausedWo))">Chiudi</MudButton>
                                            </div>
                                        </MudPaper>
                                    }
                                }

                                @* ── Quotations section ── *@
                                <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Quotations (@deal.Quotations.Count)</MudText>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="mb-2"
                                           OnClick="@(() => OpenQuotationForm(deal.Id))">Aggiungi Quotation</MudButton>

                                @if (_showNewQuotation && _quotationDealId == deal.Id)
                                {
                                    <MudCard Class="mb-3 pa-3 bc-commercial-pane" Outlined="true">
                                        <MudText Typo="Typo.subtitle2" Class="mb-2">Nuova Quotation</MudText>

                                        @* ═══════ SERVIZI ═══════ *@
                                        <MudPaper Class="quot-section svc-section mb-2" Outlined="true">
                                            <div class="quot-section-header">
                                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                                                <span class="quot-section-title">Servizi</span>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@_quotationServices.Count</MudChip>
                                            </div>
                                            <div class="quot-section-body">
                                                @{
                                                    var svcSlots = State.Slots.Where(s => s.CanBook(1)).OrderBy(s => s.Date).ToList();
                                                }
                                                @foreach (var s in _quotationServices.ToList())
                                                {
                                                    var svc = s;
                                                    <MudPaper Outlined="true" Class="item-card svc-item mb-2">
                                                        <div class="item-card-head">
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@svc.Type</MudChip>
                                                            @if (svc.ScheduledDate != null)
                                                            { <MudChip T="string" Size="Size.Small" Color="Color.Success">@svc.ScheduledDate?.ToString("dd/MM") @svc.ScheduledSlot</MudChip> }
                                                            @if (svc.IsAutonomous) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Store">Autonomo</MudChip> }
                                                            <span class="ms-auto"></span>
                                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _quotationServices.Remove(svc))" />
                                                        </div>
                                                        <div class="d-flex gap-2 align-center mt-1 flex-wrap">
                                                            @if (svcSlots.Count > 0)
                                                            {
                                                                <MudSelect T="string" Value="@(svc.ScheduledDate != null ? State.Slots.FirstOrDefault(sl => sl.Date == svc.ScheduledDate)?.Id ?? "" : "")"
                                                                           Label="Slot" Dense="true" Margin="Margin.Dense" Style="max-width:260px;"
                                                                           ValueChanged="@(slotId => { var sl = State.Slots.FirstOrDefault(x => x.Id == slotId); if (sl != null) { svc.ScheduledDate = sl.Date; svc.ScheduledSlot = sl.Id; } else { svc.ScheduledDate = null; svc.ScheduledSlot = null; } StateHasChanged(); })">
                                                                    @foreach (var slot in svcSlots.Take(20))
                                                                    {
                                                                        <MudSelectItem T="string" Value="@slot.Id">@slot.Date.ToString("dd/MM ddd") (@($"{slot.MaxVolume - slot.UsedVolume:F0}")m³)</MudSelectItem>
                                                                    }
                                                                </MudSelect>
                                                            }
                                                            <MudSelect T="string" Value="@(svc.ServiceAddress?.AreaId ?? "")" Label="Area" Dense="true" Margin="Margin.Dense" Style="max-width:120px;"
                                                                       ValueChanged="@(areaId => { if (svc.ServiceAddress != null) svc.ServiceAddress = svc.ServiceAddress with { AreaId = areaId }; StateHasChanged(); })">
                                                                @foreach (var area in State.Areas)
                                                                { <MudSelectItem T="string" Value="@area.Id">@area.Name</MudSelectItem> }
                                                            </MudSelect>
                                                            <MudSwitch T="bool" Value="@svc.IsAutonomous"
                                                                       ValueChanged="@((bool v) => { svc.IsAutonomous = v; StateHasChanged(); })"
                                                                       Color="Color.Info" Size="Size.Small">
                                                                <MudText Typo="Typo.caption">Self-service</MudText>
                                                            </MudSwitch>
                                                        </div>

                                                        @* "Richiedi sopralluogo" non e' disponibile nella Quotation in costruzione (Draft).
                                                           L'azione e' visibile solo dopo Confirm (stato InProgress in poi) — vedi DDD5 §4.8. *@

                                                        @* ── MovingIds pairing (DDD5 §2.2e) ── *@
                                                        @{
                                                            WeTacoo.Domain.Commercial.Enums.ServiceBookedType? complType = svc.Type switch
                                                            {
                                                                WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Ritiro => WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Consegna,
                                                                WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Consegna => WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Ritiro,
                                                                _ => null
                                                            };
                                                            var complements = complType != null
                                                                ? _quotationServices.Where(x => x.Type == complType).ToList()
                                                                : new List<WeTacoo.Domain.Commercial.Entities.ServiceBooked>();
                                                        }
                                                        @if (complements.Count > 0)
                                                        {
                                                            <div class="d-flex gap-1 align-center mt-1 flex-wrap">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                    <MudIcon Icon="@Icons.Material.Filled.SyncAlt" Size="Size.Small" />
                                                                    Appaia con (@(svc.Type == WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Ritiro ? "consegne alimentate" : "ritiri di provenienza")):
                                                                </MudText>
                                                                @foreach (var compl in complements)
                                                                {
                                                                    var complRef = compl;
                                                                    var isPaired = svc.MovingIds.Contains(complRef.Id);
                                                                    <MudChip T="string" Size="Size.Small"
                                                                             Color="@(isPaired ? Color.Primary : Color.Default)"
                                                                             Variant="@(isPaired ? Variant.Filled : Variant.Outlined)"
                                                                             OnClick="@(() => TogglePairing(svc, complRef))">
                                                                        @complRef.Type @(complRef.ServiceAddress?.ZipCode ?? complRef.Id.Substring(0, Math.Min(6, complRef.Id.Length)))
                                                                    </MudChip>
                                                                }
                                                            </div>
                                                        }
                                                    </MudPaper>
                                                }
                                                <div class="d-flex gap-2 align-center flex-wrap">
                                                    <MudSelect T="WeTacoo.Domain.Commercial.Enums.ServiceBookedType?" Label="+ Aggiungi servizio" Dense="true" Style="max-width:170px" Margin="Margin.Dense"
                                                               Value="_newQuotSvcType"
                                                               ValueChanged="@((WeTacoo.Domain.Commercial.Enums.ServiceBookedType? t) => { if (t != null) { _newQuotSvcType = t; AddServiceToNewQuotation(); _newQuotSvcType = null; StateHasChanged(); } })">
                                                        @foreach (var t in Enum.GetValues<WeTacoo.Domain.Commercial.Enums.ServiceBookedType>())
                                                        { <MudSelectItem T="WeTacoo.Domain.Commercial.Enums.ServiceBookedType?" Value="@t">@t</MudSelectItem> }
                                                    </MudSelect>
                                                    <MudButton Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                                                               OnClick="AddTraslocoToNewQuotation">+ Trasloco (Ritiro+Consegna)</MudButton>
                                                </div>
                                            </div>
                                        </MudPaper>

                                        @* Object selector — for delivery/disposal from active warehouse *@
                                        @{
                                            var needsObjectSelection = _quotationServices.Any(s =>
                                                s.Type is WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Consegna
                                                    or WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Smaltimento);
                                            var warehouseObjects = GetDealObjectsOnWarehouse(deal.Id);
                                        }
                                        @if (needsObjectSelection && warehouseObjects.Count > 0)
                                        {
                                            <MudText Typo="Typo.caption" Class="mb-1"><b>Oggetti dal deposito (@warehouseObjects.Count disponibili)</b></MudText>
                                            <MudPaper Class="pa-2 mb-2" Outlined="true" Style="max-height:200px; overflow-y:auto;">
                                                @foreach (var obj in warehouseObjects)
                                                {
                                                    var o = obj;
                                                    <div class="d-flex align-center gap-2">
                                                        <MudCheckBox T="bool" Value="@(_selectedObjectIds.Contains(o.Id))"
                                                                     ValueChanged="@(v => { ToggleObjectSelection(o.Id); StateHasChanged(); })"
                                                                     Dense="true" Size="Size.Small" />
                                                        <MudText Typo="Typo.caption">@o.Name — @($"{o.Volume:F1}") m³</MudText>
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@o.Status</MudChip>
                                                    </div>
                                                }
                                            </MudPaper>
                                            @if (_selectedObjectIds.Count > 0)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Info" Class="mb-2">@_selectedObjectIds.Count oggetti selezionati — @warehouseObjects.Where(o => _selectedObjectIds.Contains(o.Id)).Sum(o => o.Volume).ToString("F1") m³</MudText>
                                            }
                                        }
                                        else if (needsObjectSelection && warehouseObjects.Count == 0)
                                        {
                                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">Nessun oggetto in magazzino per questo Deal. Il servizio verra' creato senza selezione esplicita.</MudAlert>
                                        }

                                        @* ═══════ PRODOTTI ═══════ *@
                                        <MudPaper Class="quot-section prod-section mb-2" Outlined="true">
                                            <div class="quot-section-header">
                                                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" />
                                                <span class="quot-section-title">Prodotti</span>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_quotationProducts.Count</MudChip>
                                            </div>
                                            <div class="quot-section-body">
                                                @if (_quotationProducts.Count > 0)
                                                {
                                                    @foreach (var p in _quotationProducts.ToList())
                                                    {
                                                        var prod = p;
                                                        <MudPaper Outlined="true" Class="item-card prod-item mb-2">
                                                            <div class="item-card-head">
                                                                <span class="item-card-title">@prod.Name</span>
                                                                <span class="ms-auto"><b>@prod.Price.ToString("C")</b></span>
                                                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _quotationProducts.Remove(prod))" />
                                                            </div>
                                                        </MudPaper>
                                                    }
                                                }
                                                <div class="d-flex gap-2 align-center flex-wrap">
                                                    <MudSelect T="string" Label="+ Da catalogo" Dense="true" Style="max-width:280px" Margin="Margin.Dense"
                                                               ValueChanged="@(id => { _selectedProductTemplateId = id; AddProductToNewQuotation(); })">
                                                        @foreach (var pt in State.ProductTemplates)
                                                        { <MudSelectItem T="string" Value="@pt.Id">@pt.Name (@pt.BasePrice.ToString("C"))</MudSelectItem> }
                                                    </MudSelect>
                                                </div>
                                                <div class="d-flex gap-2 align-center flex-wrap mt-2">
                                                    <MudTextField @bind-Value="_customProductName" Label="Custom" Dense="true" Style="max-width:160px" Margin="Margin.Dense" Placeholder="es. Supplemento" />
                                                    <MudNumericField @bind-Value="_customProductPrice" Label="Prezzo" Format="N2" Style="max-width:100px" Margin="Margin.Dense" HideSpinButtons="true" />
                                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                                               Disabled="@(string.IsNullOrWhiteSpace(_customProductName) || _customProductPrice <= 0)"
                                                               OnClick="AddCustomProductToNewQuotation">+ Aggiungi custom</MudButton>
                                                </div>
                                            </div>
                                        </MudPaper>

                                        @* ═══════ PIANO DEPOSITO ═══════ *@
                                        @if (deal.ActivePlan == null)
                                        {
                                            <MudPaper Class="quot-section plan-section mb-2" Outlined="true">
                                                <div class="quot-section-header">
                                                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                                                    <span class="quot-section-title">Piano Deposito</span>
                                                    <span class="quot-section-hint">Se accettata con piano, il Deal diventa Recurring.</span>
                                                </div>
                                                <div class="quot-section-body">
                                                    <MudCheckBox T="bool" @bind-Value="_includePlan" Dense="true" Size="Size.Small">Includi piano deposito mensile</MudCheckBox>
                                                    @if (_includePlan)
                                                    {
                                                        <div class="d-flex gap-2 align-center mb-2 flex-wrap mt-1">
                                                            <MudTextField @bind-Value="_newQuotPlanDesc" Label="Descrizione" Dense="true" Style="max-width:160px" Margin="Margin.Dense" Placeholder="es. Box 10m3" />
                                                            <MudNumericField @bind-Value="_newQuotPlanFee" Label="EUR/mese" Format="N2" Style="max-width:100px" Margin="Margin.Dense" HideSpinButtons="true" />
                                                            <MudNumericField @bind-Value="_newQuotPlanM3" Label="m3" Format="N1" Style="max-width:80px" Margin="Margin.Dense" HideSpinButtons="true" />
                                                        </div>
                                                    }
                                                </div>
                                            </MudPaper>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Dense="true" NoIcon="true" Class="mb-2">
                                                Piano gia' attivo (@($"{deal.ActivePlan.CurrentM3:F1}m3, {deal.ActivePlan.MonthlyFee:C}/mese")). Questa quotation aggiungera' servizi senza modificare il piano.
                                            </MudAlert>
                                        }

                                        @if (_quotationServices.Count == 0)
                                        {
                                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">Aggiungi almeno un servizio per generare WorkOrder all'accettazione.</MudAlert>
                                        }

                                        <div class="d-flex gap-2 mt-2">
                                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => CreateQuotation(deal))">Crea Quotation</MudButton>
                                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _showNewQuotation = false)">Annulla</MudButton>
                                        </div>
                                    </MudCard>
                                }

                                <MudExpansionPanels MultiExpansion="true" Class="mb-2">
                                @foreach (var q in deal.Quotations)
                                {
                                    <MudExpansionPanel Class="bc-commercial-pane" Style="@(q.IsAccepted ? "border-left-color: var(--mud-palette-success) !important;" : "")">
                                        <TitleContent>
                                            <div class="d-flex justify-space-between align-center" style="width:100%">
                                                <div class="d-flex align-center gap-1">
                                                    <MudText Typo="Typo.body2"><b>@q.Id</b></MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(q.Status.ToString())">@q.Status</MudChip>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@q.Products.Count prod, @q.Services.Count svc</MudText>
                                                </div>
                                                <div class="d-flex align-center gap-1">
                                                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">@q.TotalPrice.ToString("C")</MudText>
                                                    <EntityActions Kind="Quotation" Ids="@(new[] { deal.Id, q.Id })" Entity="q" OnChanged="StateHasChanged" />
                                                </div>
                                            </div>
                                        </TitleContent>
                                        <ChildContent>

                                        @* ═══════ SERVIZI CARD ═══════ *@
                                        <MudPaper Class="quot-section svc-section mb-2" Outlined="true">
                                            <div class="quot-section-header">
                                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                                                <span class="quot-section-title">Servizi</span>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@q.Services.Count</MudChip>
                                            </div>
                                            <div class="quot-section-body">
                                                @foreach (var s in q.Services.ToList())
                                                {
                                                    var svc = s;
                                                    <MudPaper Outlined="true" Class="item-card svc-item mb-2">
                                                        <div class="item-card-head">
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@svc.Type</MudChip>
                                                            <span class="item-card-title">@(svc.ServiceAddress?.ZipCode ?? "—")</span>
                                                            <span class="ms-auto"><EntityActions Kind="ServiceBooked" Ids="@(new[] { deal.Id, q.Id, svc.Id })" Entity="svc" OnChanged="StateHasChanged" /></span>
                                                        </div>
                                                        <div class="item-card-chips">
                                                            @{ var svcAreaName = State.Areas.FirstOrDefault(a => a.Id == (svc.ServiceAddress?.AreaId ?? deal.AreaId))?.Name; }
                                                            @if (svcAreaName != null) { <MudChip T="string" Size="Size.Small">@svcAreaName</MudChip> }
                                                            @if (svc.ScheduledDate != null)
                                                            {
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Success">@svc.ScheduledDate?.ToString("dd/MM") @svc.ScheduledSlot</MudChip>
                                                            }
                                                            <MudChip T="string" Size="Size.Small" Color="@SvcBookedStatusColor(svc.Status)">SB: @svc.Status</MudChip>
                                                            @if (svc.IsAutonomous) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Store">Autonomo</MudChip> }
                                                        </div>
                                                        @if (!q.IsAccepted)
                                                        {
                                                            <div class="item-card-actions">
                                                                <MudSwitch T="bool" Value="@svc.IsAutonomous"
                                                                           ValueChanged="@((bool v) => { svc.IsAutonomous = v; State.NotifyStateChanged(); })"
                                                                           Color="Color.Info" Size="Size.Small">
                                                                    <MudText Typo="Typo.caption">Self-service (cliente al magazzino)</MudText>
                                                                </MudSwitch>
                                                            </div>
                                                        }
                                                        <div class="item-card-actions">
                                                            @if (svc.MovingIds.Count > 0)
                                                            {
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.SyncAlt">Trasloco (@svc.MovingIds.Count appaiato)</MudChip>
                                                            }
                                                            @if (q.IsAccepted && svc.Status is not WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.Completed and not WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.Cancelled)
                                                            {
                                                                <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                                                           OnClick="@(() => CancelServiceBooked(svc))">Annulla servizio</MudButton>
                                                            }
                                                            @if (q.IsAccepted && svc.QuestionnaireId != null)
                                                            {
                                                                var svcQuest = State.Questionnaires.FirstOrDefault(qst => qst.Id == svc.QuestionnaireId);
                                                                var svcWo = svc.WorkOrderId != null ? State.WorkOrders.FirstOrDefault(w => w.Id == svc.WorkOrderId) : null;
                                                                @if (svcQuest != null && !svcQuest.IsVerified && svc.Status == WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.ToComplete)
                                                                {
                                                                    <MudButton Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                                                                               OnClick="@(() => { if (svcWo != null) VerifyQuestionnaireAndReady(svcQuest, svc, svcWo); })">Questionario completato</MudButton>
                                                                }
                                                            }
                                                            @* "Richiedi sopralluogo" (DDD5 §4.8, review 2026-04-17).
                                                               Crea un WorkOrder Sopralluogo standalone (non un ServiceBooked) e porta il ServiceBooked in WaitingInspection.
                                                               Visibile solo su Quotation gia' confermata (stato != Draft) e ServiceBooked in ToAccept.
                                                               Il completamento NON avviene dalla Quotation: e' automatico alla chiusura dello Shift (Execution). *@
                                                            @if (q.Status != WeTacoo.Domain.Commercial.Enums.QuotationStatus.Draft
                                                                 && svc.Status == WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.ToAccept
                                                                 && string.IsNullOrEmpty(svc.InspectionId))
                                                            {
                                                                @if (_inspectionDraftSvcId == svc.Id)
                                                                {
                                                                    var inspSlots = State.Slots
                                                                        .Where(sl => sl.CanBook(1) && (svc.ServiceAddress?.AreaId == null || sl.AreaId == svc.ServiceAddress.AreaId))
                                                                        .OrderBy(sl => sl.Date).ToList();
                                                                    <div class="d-flex gap-1 align-center flex-wrap">
                                                                        <MudSelect T="string" Value="_inspectionDraftSlotId" ValueChanged="@(v => _inspectionDraftSlotId = v)" Label="Slot sopralluogo" Dense="true" Margin="Margin.Dense" Style="max-width:260px">
                                                                            @foreach (var slot in inspSlots.Take(20))
                                                                            { <MudSelectItem T="string" Value="@slot.Id">@slot.Date.ToString("dd/MM ddd") (@($"{slot.MaxVolume - slot.UsedVolume:F0}")m³)</MudSelectItem> }
                                                                        </MudSelect>
                                                                        <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                                                                   OnClick="@(() => ConfirmRichiediSopralluogo(svc))">Conferma</MudButton>
                                                                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                                                                   OnClick="@(() => { _inspectionDraftSvcId = null; _inspectionDraftSlotId = null; })">Annulla</MudButton>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                                                               StartIcon="@Icons.Material.Filled.Visibility"
                                                                               OnClick="@(() => { _inspectionDraftSvcId = svc.Id; _inspectionDraftSlotId = null; })">Richiedi sopralluogo</MudButton>
                                                                }
                                                            }
                                                            @if (svc.Status == WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.WaitingInspection && !string.IsNullOrEmpty(svc.InspectionId))
                                                            {
                                                                var insWo = State.WorkOrders.FirstOrDefault(w => w.Id == svc.InspectionId);
                                                                var insLabel = insWo?.ScheduledDate != null
                                                                    ? $"Sopralluogo {insWo.ScheduledDate:dd/MM} — WO {svc.InspectionId.Substring(0, Math.Min(6, svc.InspectionId.Length))}"
                                                                    : $"Sopralluogo in corso — WO {svc.InspectionId.Substring(0, Math.Min(6, svc.InspectionId.Length))}";
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Visibility">
                                                                    @insLabel
                                                                </MudChip>
                                                                <MudText Typo="Typo.caption" Class="ml-2">Conclusione automatica a chiusura Shift</MudText>
                                                            }
                                                            @if (!string.IsNullOrEmpty(svc.InspectionId) && svc.Status != WeTacoo.Domain.Commercial.Enums.ServiceBookedStatus.WaitingInspection)
                                                            {
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Visibility">
                                                                    Sopralluogo WO @svc.InspectionId.Substring(0, Math.Min(6, svc.InspectionId.Length))
                                                                </MudChip>
                                                            }
                                                        </div>
                                                    </MudPaper>
                                                }
                                                @if (!q.IsAccepted)
                                                {
                                                    <MudSelect T="WeTacoo.Domain.Commercial.Enums.ServiceBookedType" Label="+ Aggiungi servizio" Dense="true" Style="max-width:180px" Margin="Margin.Dense"
                                                               ValueChanged="@(t => { q.Services.Add(new WeTacoo.Domain.Commercial.Entities.ServiceBooked { Type = t, ServiceAddress = new WeTacoo.Domain.Commercial.ValueObjects.Address(_inlineSvcZip) }); _inlineSvcZip = ""; State.NotifyStateChanged(); })">
                                                        @foreach (var t in Enum.GetValues<WeTacoo.Domain.Commercial.Enums.ServiceBookedType>())
                                                        { <MudSelectItem T="WeTacoo.Domain.Commercial.Enums.ServiceBookedType" Value="@t">@t</MudSelectItem> }
                                                    </MudSelect>
                                                }
                                            </div>
                                        </MudPaper>

                                        @* ═══════ PRODOTTI CARD ═══════ *@
                                        <MudPaper Class="quot-section prod-section mb-2" Outlined="true">
                                            <div class="quot-section-header">
                                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                                                <span class="quot-section-title">Prodotti</span>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@q.Products.Count</MudChip>
                                                <span class="ms-auto quot-section-total">@q.TotalPrice.ToString("C")</span>
                                            </div>
                                            <div class="quot-section-body">
                                                @foreach (var p in q.Products.ToList())
                                                {
                                                    var prod = p;
                                                    <MudPaper Outlined="true" Class="item-card prod-item mb-2">
                                                        <div class="item-card-head">
                                                            <span class="item-card-title">@prod.Name</span>
                                                            @if (!string.IsNullOrWhiteSpace(prod.Description))
                                                            {
                                                                <span class="item-card-sub">@prod.Description</span>
                                                            }
                                                            <span class="ms-auto">
                                                                @if (!q.IsAccepted)
                                                                {
                                                                    <MudNumericField @bind-Value="prod.Price" Format="N2" HideSpinButtons="true" Style="max-width:110px" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentText="EUR" />
                                                                }
                                                                else
                                                                {
                                                                    <b>@prod.Price.ToString("C")</b>
                                                                }
                                                            </span>
                                                            <EntityActions Kind="Product" Ids="@(new[] { deal.Id, q.Id, prod.Id })" Entity="prod" OnChanged="StateHasChanged" />
                                                        </div>
                                                    </MudPaper>
                                                }
                                                @if (!q.IsAccepted)
                                                {
                                                    <MudSelect T="string" Label="+ Aggiungi prodotto" Dense="true" Style="max-width:260px" Margin="Margin.Dense"
                                                               ValueChanged="@(id => { _inlineProductId = id; AddProductToExistingQuotation(q); })">
                                                        @foreach (var pt in State.ProductTemplates)
                                                        { <MudSelectItem T="string" Value="@pt.Id">@pt.Name (@pt.BasePrice.ToString("C"))</MudSelectItem> }
                                                    </MudSelect>
                                                }
                                            </div>
                                        </MudPaper>

                                        @* ═══════ PIANO DEPOSITO CARD ═══════ *@
                                        @if (deal.ActivePlan == null)
                                        {
                                            <MudPaper Class="quot-section plan-section mb-2" Outlined="true">
                                                <div class="quot-section-header">
                                                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                                                    <span class="quot-section-title">Piano Deposito</span>
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@q.DraftPlans.Count</MudChip>
                                                    <span class="quot-section-hint">Se accettata con un DraftPlan, il Deal diventa Recurring.</span>
                                                </div>
                                                <div class="quot-section-body">
                                                    @foreach (var dp in q.DraftPlans.ToList())
                                                    {
                                                        var plan = dp;
                                                        <MudPaper Outlined="true" Class="item-card plan-item mb-2">
                                                            @if (!q.IsAccepted)
                                                            {
                                                                <div class="item-card-head">
                                                                    <MudTextField @bind-Value="plan.Description" Label="Descrizione" Dense="true" Style="max-width:220px" Margin="Margin.Dense" />
                                                                    <MudNumericField @bind-Value="plan.MonthlyFee" Label="EUR/mese" Format="N2" Dense="true" Style="max-width:110px" Margin="Margin.Dense" HideSpinButtons="true" />
                                                                    <MudNumericField @bind-Value="plan.EstimatedM3" Label="m³" Format="N1" Dense="true" Style="max-width:90px" Margin="Margin.Dense" HideSpinButtons="true" />
                                                                    <EntityActions Kind="DraftPlan" Ids="@(new[] { deal.Id, q.Id, plan.Id })" Entity="plan" OnChanged="StateHasChanged" />
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="item-card-head">
                                                                    <span class="item-card-title">@plan.Description</span>
                                                                    <span class="ms-auto"><b>@plan.MonthlyFee.ToString("C")</b> / mese</span>
                                                                    <span>@plan.EstimatedM3.ToString("F1") m³</span>
                                                                    <EntityActions Kind="DraftPlan" Ids="@(new[] { deal.Id, q.Id, plan.Id })" Entity="plan" OnChanged="StateHasChanged" />
                                                                </div>
                                                            }
                                                        </MudPaper>
                                                    }
                                                    @if (!q.IsAccepted && q.DraftPlans.Count == 0)
                                                    {
                                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                                                   OnClick="@(() => { q.DraftPlans.Add(new WeTacoo.Domain.Commercial.Entities.DraftPlan { Description = "Piano deposito", MonthlyFee = 89.90m, EstimatedM3 = 10, AreaId = deal.AreaId }); State.NotifyStateChanged(); })">+ Piano</MudButton>
                                                    }
                                                </div>
                                            </MudPaper>
                                        }
                                        else if (q.DraftPlans.Count == 0 && !q.IsAccepted)
                                        {
                                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">Servizio aggiuntivo su piano attivo — nessun nuovo piano necessario.</MudAlert>
                                        }

                                        @* Flusso stati Quotation: Bozza -> In lavorazione -> Finalizzata -> Accettata (via client) *@
                                        @if (q.Status == WeTacoo.Domain.Commercial.Enums.QuotationStatus.Draft)
                                        {
                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mt-2"
                                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                                       OnClick="@(() => { q.Confirm(); State.NotifyStateChanged(); Snackbar.Add("Quotation → In lavorazione", Severity.Success); })">Conferma (Bozza → In lavorazione)</MudButton>
                                        }
                                        @if (q.Status == WeTacoo.Domain.Commercial.Enums.QuotationStatus.InProgress)
                                        {
                                            <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Class="mt-2"
                                                       StartIcon="@Icons.Material.Filled.LockOpen"
                                                       OnClick="@(() => { q.TakeOver(); State.NotifyStateChanged(); Snackbar.Add("Quotation → Bozza (riapertura modifiche)", Severity.Info); })">Riapri in Bozza</MudButton>
                                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="mt-2 ml-1"
                                                       StartIcon="@Icons.Material.Filled.CheckCircle"
                                                       OnClick="@(() => FinalizeAndAccept(deal, q))">
                                                @((!deal.Quotations.Any(x => x.Services.Any(s => s.WorkOrderId != null))) ? "Finalizza e accetta (cliente)" : "Finalizza e accetta (servizio aggiuntivo)")
                                            </MudButton>
                                        }
                                        @* Fallback: Quotation gia' Finalizzata (es. tramite scenario) ma cascade non ancora girata *@
                                        @{
                                            var cascadeNotRun = q.Services.All(s => s.WorkOrderId == null);
                                        }
                                        @if (q.Status == WeTacoo.Domain.Commercial.Enums.QuotationStatus.Finalized && cascadeNotRun)
                                        {
                                            var isFirstAccept = !deal.Quotations.Any(x => x.Services.Any(s => s.WorkOrderId != null));
                                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="mt-2 ml-1"
                                                       StartIcon="@Icons.Material.Filled.CheckCircle"
                                                       OnClick="@(() => AcceptQuotation(deal, q))">
                                                @(isFirstAccept ? "Accetta Quotation (cliente)" : "Accetta (servizio aggiuntivo)")
                                            </MudButton>
                                        }

                                        @* Da adeguare -> Completato (conferma adeguamento post-esecuzione) *@
                                        @if (q.Status == WeTacoo.Domain.Commercial.Enums.QuotationStatus.ToAdjust)
                                        {
                                            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2" NoIcon="true">
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.caption"><b>Quotation da adeguare</b> — differenze tra preventivato ed eseguito da riconciliare</MudText>
                                                    <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                               StartIcon="@Icons.Material.Filled.CheckCircle"
                                                               OnClick="@(() => ConfirmAdjustmentAndComplete(deal, q))">Conferma adeguamento</MudButton>
                                                </div>
                                            </MudAlert>
                                        }

                                        @* Da verificare -> Finalizzato (verifica pre-esecuzione / durante esecuzione) *@
                                        @if (q.Status == WeTacoo.Domain.Commercial.Enums.QuotationStatus.ToVerify)
                                        {
                                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2" NoIcon="true">
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.caption"><b>Quotation da verificare</b></MudText>
                                                    <MudButton Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                                                               OnClick="@(() => { q.Verify(); State.NotifyStateChanged(); Snackbar.Add("Quotation verificata — torna a Finalizzato", Severity.Success); })">Verifica effettuata</MudButton>
                                                </div>
                                            </MudAlert>
                                        }

                                        @* Aggiungi pagamento — disponibile su qualsiasi Quotation accettata *@
                                        @if (q.IsAccepted)
                                        {
                                            var qPayments = State.Payments.Where(p => p.QuotationId == q.Id).ToList();
                                            <div class="mt-2">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Pagamenti: @qPayments.Count (@qPayments.Sum(p => p.TotalAmount).ToString("C"))</MudText>
                                                <div class="d-flex align-center gap-2 mt-1">
                                                    <MudNumericField @bind-Value="_newPaymentAmount" Label="Importo" Format="N2" Style="max-width:120px" Margin="Margin.Dense" HideSpinButtons="true" Adornment="Adornment.Start" AdornmentText="EUR" />
                                                    <MudSelect @bind-Value="_newPaymentType" Label="Tipo" T="string" Style="max-width:130px" Dense="true" Margin="Margin.Dense">
                                                        <MudSelectItem T="string" Value="@("OneOff")">One-off</MudSelectItem>
                                                        <MudSelectItem T="string" Value="@("Recurring")">Ricorrente</MudSelectItem>
                                                    </MudSelect>
                                                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                               StartIcon="@Icons.Material.Filled.AddCard"
                                                               Disabled="@(_newPaymentAmount <= 0)"
                                                               OnClick="@(() => CreatePaymentForQuotation(deal, q))">Aggiungi pagamento</MudButton>
                                                </div>
                                            </div>
                                        }
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                                </MudExpansionPanels>

                                @* ActivePlan info *@
                                @if (deal.ActivePlan != null)
                                {
                                    <MudCard Class="mt-2 pa-2" Outlined="true" Style="border-left: 3px solid var(--mud-palette-success);">
                                        <MudText Typo="Typo.caption" Class="mb-1"><b>Piano Attivo</b> — @deal.ActivePlan.ObjectCount oggetti</MudText>
                                        <div class="d-flex gap-2 align-center">
                                            <MudNumericField @bind-Value="deal.ActivePlan.CurrentM3" Label="m³" Format="N1" Style="max-width:80px" Margin="Margin.Dense" HideSpinButtons="true" />
                                            <MudNumericField @bind-Value="deal.ActivePlan.MonthlyFee" Label="EUR/mese" Format="N2" Style="max-width:100px" Margin="Margin.Dense" HideSpinButtons="true" />
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                                       OnClick="@(() => { deal.ActivePlan.History.Add($"{DateTime.UtcNow:u} Manual update: {deal.ActivePlan.CurrentM3:F1}m³, {deal.ActivePlan.MonthlyFee:C}"); State.NotifyStateChanged(); Snackbar.Add("Piano aggiornato", Severity.Success); })">Salva</MudButton>
                                        </div>
                                        @if (deal.ActivePlan.History.Count > 0)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@deal.ActivePlan.History.Last()</MudText>
                                        }
                                    </MudCard>
                                }

                                @* Status history *@
                                @if (deal.StatusHistory.Count > 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-2"><b>Storico:</b></MudText>
                                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                                        @foreach (var h in deal.StatusHistory.TakeLast(5))
                                        {
                                            <MudTimelineItem Color="Color.Info" Size="Size.Small">
                                                <MudText Typo="Typo.caption">@h</MudText>
                                            </MudTimelineItem>
                                        }
                                    </MudTimeline>
                                }
                            </ChildContent>
                        </MudExpansionPanel>
                    }
                    </MudExpansionPanels>

                    @* ── 3. WORK ORDERS ── *@
                    @if (GetLeadWorkOrders().Any())
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6" Class="mb-2"><span class="bc-section-label op">Operational</span><MudIcon Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" /> WorkOrder</MudText>
                        @foreach (var wo in GetLeadWorkOrders())
                        {
                            <MudCard Class="mb-2 bc-op-pane" Elevation="1">
                                <MudCardContent>
                                    @{
                                        var woDeal = State.Deals.FirstOrDefault(d => d.LeadId == _selectedLeadId
                                            && d.Quotations.Any(q => q.Services.Any(s => s.WorkOrderId == wo.Id)));
                                        var woStatus = wo.Status.ToString();
                                    }
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudText Typo="Typo.body2"><b>WO @wo.Id.Substring(0, Math.Min(8, wo.Id.Length))...</b></MudText>
                                        <MudChip T="string" Size="Size.Small">@wo.ServiceType.Type</MudChip>
                                        @if (wo.ServiceType.IsAutonomous) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Store">Autonomo</MudChip> }
                                        @if (wo.ServiceType.AreaId != null)
                                        { <MudChip T="string" Size="Size.Small" Color="Color.Default">@(State.Areas.FirstOrDefault(a => a.Id == wo.ServiceType.AreaId)?.Name ?? wo.ServiceType.AreaId)</MudChip> }
                                        <MudChip T="string" Size="Size.Small" Color="@WOStatusColor(woStatus)">@woStatus</MudChip>
                                        <MudSpacer />
                                        <EntityActions Kind="WorkOrder" Ids="@(new[] { wo.Id })" Entity="wo" OnChanged="StateHasChanged" />
                                    </div>
                                    <MudText Typo="Typo.caption">
                                        @(wo.ServiceAddress ?? "-")
                                        @if (wo.ScheduledDate != null) { <text> | @wo.ScheduledDate?.ToString("dd/MM/yyyy") @wo.ScheduledSlot</text> }
                                        | Creato: @wo.CreatedAt.ToString("dd/MM HH:mm")
                                    </MudText>
                                    @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToVerify && woDeal != null)
                                    {
                                        var volumeDelta = wo.ActualVolume - wo.EstimatedVolume;
                                        var objectsOnWh = State.Objects.Count(o => o.DealId == woDeal.Id && o.Status == WeTacoo.Domain.Execution.Enums.ObjectStatus.OnWarehouse);
                                        <MudCard Class="mt-2 pa-2" Outlined="true" Style="border-left: 3px solid var(--mud-palette-warning);">
                                            <MudText Typo="Typo.caption"><b>Adeguamento richiesto</b></MudText>
                                            <div class="d-flex gap-4 mt-1">
                                                <div>
                                                    <MudText Typo="Typo.caption">Stimato: <b>@($"{wo.EstimatedVolume:F1}") m³</b></MudText>
                                                    <MudText Typo="Typo.caption">Recuperato: <b>@($"{wo.ActualVolume:F1}") m³</b></MudText>
                                                </div>
                                                <div>
                                                    <MudText Typo="Typo.caption" Color="@(volumeDelta > 0 ? Color.Error : volumeDelta < 0 ? Color.Success : Color.Default)">
                                                        Delta: <b>@($"{volumeDelta:+0.0;-0.0}") m³</b>
                                                    </MudText>
                                                    <MudText Typo="Typo.caption">Oggetti in magazzino: <b>@objectsOnWh</b></MudText>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 align-center mt-1">
                                                <MudNumericField @bind-Value="wo.ActualVolume" Label="Vol. recuperato" Format="N1"
                                                                 Style="max-width:100px" Margin="Margin.Dense" HideSpinButtons="true" />
                                                <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                                           OnClick="@(() => ApplyAdjustment(wo, woDeal))">Applica Adeguamento</MudButton>
                                            </div>
                                            <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-1">La differenza viene registrata. Per creare pagamenti aggiuntivi usa il bottone sulla Quotation.</MudText>
                                        </MudCard>
                                    }

                                    <div class="d-flex gap-2 mt-2 flex-wrap align-center">
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Completing)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">In completamento — questionario da verificare</MudChip>
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Da programmare — crea Mission nel Planning</MudChip>
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled)
                                        {
                                            @if (State.Shifts.Any(s => s.ServiceEntries.Any(se => se.ServiceId == wo.Id)))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Shift creato — vedi Planning</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Da assegnare a Mission (vedi Planning sotto)</MudChip>
                                            }
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.InExecution)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">In esecuzione — vedi Shift</MudChip>
                                            <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                                       OnClick="@(() => ChiusuraAnticipataWo(wo))">Chiusura anticipata</MudButton>
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Paused)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">In pausa — vedi Deal per la decisione Commercial</MudChip>
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToVerify)
                                        {
                                            <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                       OnClick="@(() => ConcludeWO(wo))">Verifica e concludi</MudButton>
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Concluded)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Concluso</MudChip>
                                        }
                                        @if (wo.Status == WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Cancelled)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Annullato</MudChip>
                                        }
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                        @* Trasbordo/Transfer si creano dalla pagina Operational *@
                    }

                    @* ── 4. PLANNING — sezione dedicata per giorno ── *@
                    @if (GetLeadWorkOrders().Any() || HasAnyOpsWoToPlan())
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6" Class="mb-2"><span class="bc-section-label op">Operational</span><MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" /> Planning &amp; Mission</MudText>

                        @* Crea Planning per un giorno — solo data.
                           Il Planning raggruppa le Mission di una giornata. Veicoli, team e fascia oraria
                           vivono sulla singola Mission (vedi sotto). *@
                        <MudPaper Class="pa-3 mb-2 bc-op-pane" Outlined="true">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                                Il Planning e' il contenitore di Mission per un giorno. Qui si sceglie solo la data;
                                veicoli, team e fascia oraria si definiscono quando si crea la singola Mission.
                            </MudText>
                            <div class="d-flex gap-2 align-center flex-wrap">
                                @{
                                    var planningDates = GetPlanningAvailableDates();
                                }
                                <MudSelect Value="_missionDateStr" Label="Giorno Planning" T="string" Dense="true" Style="max-width:220px" Margin="Margin.Dense"
                                           ValueChanged="@((string v) => { _missionDateStr = v; _missionDate = DateTime.TryParse(v, out var d) ? d : null; StateHasChanged(); })">
                                    @foreach (var pd in planningDates)
                                    {
                                        <MudSelectItem T="string" Value="@pd.ToString("yyyy-MM-dd")">@pd.ToString("dd/MM ddd") @(GetScheduledUnassignedWOs().Any(w => GetWOsForDate(GetScheduledUnassignedWOs(), pd).Contains(w)) ? "★" : "")</MudSelectItem>
                                    }
                                </MudSelect>
                                @if (_missionDate != null)
                                {
                                    var existingPlanning = State.Plannings.FirstOrDefault(p => p.Date.Date == _missionDate?.Date);
                                    @if (existingPlanning == null)
                                    {
                                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                   StartIcon="@Icons.Material.Filled.CalendarToday"
                                                   OnClick="@(() => CreateWorkspacePlanning())">Crea Planning</MudButton>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Planning @existingPlanning.Date.ToString("dd/MM") — @existingPlanning.Missions.Count Mission</MudChip>
                                    }
                                }
                            </div>
                            @if (_missionDate == null)
                            {
                                <MudText Typo="Typo.caption" Class="mt-2" Color="Color.Secondary">Scegli un giorno per vedere i servizi da pianificare.</MudText>
                            }
                        </MudPaper>

                        @* ════════ Mission esistenti per questo cliente — riquadro ben visibile ════════ *@
                        var leadWos = GetLeadWorkOrders().Select(w => w.Id).ToHashSet();
                        var leadPlannings = State.Plannings
                            .Where(p => p.Missions.Any(m => m.ServiceRefs.Any(sr => leadWos.Contains(sr.ServiceId))))
                            .OrderBy(p => p.Date).ToList();
                        @if (leadPlannings.Count > 0)
                        {
                            <MudPaper Class="existing-missions-box pa-3 mb-3" Elevation="2">
                                <div class="d-flex align-center gap-2 mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1"><b>Mission esistenti per questo cliente</b></MudText>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@leadPlannings.SelectMany(p => p.Missions).Count() totali</MudChip>
                                </div>
                                @foreach (var planning in leadPlannings)
                                {
                                    <MudCard Class="mb-2 bc-op-pane" Outlined="true">
                                        <MudCardContent>
                                            <div class="d-flex align-center gap-2">
                                                <MudText Typo="Typo.body2"><b>Planning @planning.Date.ToString("dd/MM/yyyy")</b> — @planning.Missions.Count Mission | @planning.Teams.Count team</MudText>
                                                <MudSpacer />
                                                <EntityActions Kind="Planning" Ids="@(new[] { planning.Id })" Entity="planning" OnChanged="StateHasChanged" />
                                            </div>
                                            @foreach (var mission in planning.Missions.Where(m => m.ServiceRefs.Any(sr => leadWos.Contains(sr.ServiceId))))
                                            {
                                                var hasShift = State.Shifts.Any(s => s.MissionId == mission.Id);
                                                var missionTeam = planning.Teams.FirstOrDefault(t => t.Id == mission.TeamId);
                                                <MudPaper Class="pa-2 mt-1" Outlined="true">
                                                    <div class="d-flex align-center gap-2 flex-wrap">
                                                        <MudChip T="string" Size="Size.Small" Color="@(mission.IsCancelled ? Color.Error : hasShift ? Color.Success : Color.Warning)">
                                                            @(mission.IsCancelled ? "Cancelled" : hasShift ? "Confermata (Shift creato)" : "Non confermata")
                                                        </MudChip>
                                                        <MudText Typo="Typo.caption"><b>Mission</b> @mission.Id.Substring(0, Math.Min(8, mission.Id.Length)) | @mission.TimeSlot</MudText>
                                                        @if (missionTeam != null)
                                                        {
                                                            <MudText Typo="Typo.caption">Team: @string.Join(", ", missionTeam.OperatorIds.Select(oid => State.Operators.FirstOrDefault(o => o.Id == oid)?.FullName ?? oid))</MudText>
                                                        }
                                                        <MudSpacer />
                                                        <EntityActions Kind="Mission" Ids="@(new[] { planning.Id, mission.Id })" Entity="mission" OnChanged="StateHasChanged" />
                                                    </div>
                                                    <div class="mt-1">
                                                        <MudText Typo="Typo.caption"><b>Servizi (@mission.ServiceRefs.Count)</b>:
                                                        @foreach (var sr in mission.ServiceRefs)
                                                        {
                                                            var srWo = State.WorkOrders.FirstOrDefault(w => w.Id == sr.ServiceId);
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-1">@(srWo?.ServiceType.Type.ToString() ?? "?") (@sr.VolumePercentage%)</MudChip>
                                                        }
                                                        </MudText>
                                                    </div>
                                                    @if (!mission.IsCancelled && !hasShift)
                                                    {
                                                        <div class="d-flex gap-2 mt-2">
                                                            <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                                       OnClick="@(() => ConfirmMissionShift(planning, mission))">Conferma → Shift</MudButton>
                                                            <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                                                       OnClick="@(() => DeleteMission(planning, mission))">Elimina Mission</MudButton>
                                                        </div>
                                                    }
                                                </MudPaper>
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                }
                            </MudPaper>
                        }

                        @* ════════ Crea nuova Mission ════════ *@
                        @if (_missionDate != null && State.Plannings.Any(p => p.Date.Date == _missionDate?.Date))
                        {
                            var currentPlanning = State.Plannings.First(p => p.Date.Date == _missionDate?.Date);
                            <MudCard Class="mb-2 bc-op-pane" Outlined="true">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle1" Class="mb-1">➕ Nuova Mission per @_missionDate?.ToString("dd/MM/yyyy")</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                                        Una Mission e' un'uscita di un team in una giornata: raggruppa i servizi che il team eseguira' insieme.
                                        Alla conferma, genera uno Shift in Execution con ServiceEntry per ciascun servizio.
                                    </MudText>

                                    @* Step 1: Servizi *@
                                    <MudText Typo="Typo.caption" Class="mb-1"><b>1. Servizi da includere</b></MudText>
                                    @{
                                        var assignableWos = GetScheduledUnassignedWOs();
                                    }
                                    @if (assignableWos.Count == 0)
                                    {
                                        <MudAlert Severity="Severity.Info" Dense="true">Nessun servizio programmabile. Appare quando il WorkOrder e' in <b>Da programmare</b> o <b>Programmato</b>.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudPaper Class="pa-2 mb-3" Outlined="true">
                                            @foreach (var wo in assignableWos)
                                            {
                                                var woId = wo.Id;
                                                var existingMissionCount = State.Plannings.SelectMany(p => p.Missions).Count(m => !m.IsCancelled && m.ServiceRefs.Any(sr => sr.ServiceId == woId));
                                                var sameDay = wo.ScheduledDate?.Date == _missionDate?.Date;
                                                var isOpsWo = wo.Type == WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational;
                                                <div class="d-flex align-center gap-2">
                                                    <MudCheckBox T="bool" Dense="true" Size="Size.Small"
                                                                 Value="@_selectedNewMissionWoIds.Contains(woId)"
                                                                 ValueChanged="@((bool ck) => { if (ck) _selectedNewMissionWoIds.Add(woId); else _selectedNewMissionWoIds.Remove(woId); StateHasChanged(); })" />
                                                    @if (isOpsWo) { <MudChip T="string" Size="Size.Small" Color="Color.Warning">OPS</MudChip> }
                                                    <MudChip T="string" Size="Size.Small" Color="@(sameDay ? Color.Info : Color.Default)">@wo.ServiceType.Type</MudChip>
                                                    @if (wo.ServiceType.IsAutonomous) { <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Store">Autonomo</MudChip> }
                                                    <MudText Typo="Typo.caption">@(wo.ServiceAddress ?? "") — data prog.: @(wo.ScheduledDate?.ToString("dd/MM") ?? "—") — @wo.Status</MudText>
                                                    @if (existingMissionCount > 0)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@existingMissionCount Mission esistenti</MudChip>
                                                    }
                                                </div>
                                            }
                                        </MudPaper>

                                        var selectedWos = assignableWos.Where(w => _selectedNewMissionWoIds.Contains(w.Id)).ToList();
                                        var allAutonomous = selectedWos.Count > 0 && selectedWos.All(w => w.ServiceType.IsAutonomous);

                                        @if (allAutonomous)
                                        {
                                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                                <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Small" />
                                                Tutti i servizi selezionati sono <b>self-service</b>: il cliente viene al magazzino. Non servono veicoli — basta un team di accoglienza.
                                            </MudAlert>
                                        }
                                        else
                                        {
                                            @* Step 2: Veicoli (solo se almeno un WO non autonomo) *@
                                            <MudText Typo="Typo.caption" Class="mb-1"><b>2. Veicoli assegnati</b></MudText>
                                            <div class="resource-grid mb-3">
                                                @foreach (var v in State.Vehicles.Where(x => x.Status == "Available"))
                                                {
                                                    var vId = v.Id;
                                                    var isSel = _selectedVehicleIds.Contains(vId);
                                                    <div class="resource-chip @(isSel ? "selected" : "")"
                                                         @onclick="@(() => { if (isSel) _selectedVehicleIds.Remove(vId); else _selectedVehicleIds.Add(vId); StateHasChanged(); })">
                                                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                                                        <div class="resource-info">
                                                            <div class="resource-name">@v.Name</div>
                                                            <div class="resource-meta">@v.Plate · @v.Capacity m³</div>
                                                        </div>
                                                        @if (isSel) { <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Primary" /> }
                                                    </div>
                                                }
                                            </div>
                                        }

                                        @* Step 3: Team *@
                                        <MudText Typo="Typo.caption" Class="mb-1"><b>3. Team esecutivo</b></MudText>
                                        <div class="d-flex gap-2 align-center flex-wrap mb-2">
                                            <MudSelect @bind-Value="_selectedTeamId" T="string" Label="Seleziona team esistente" Dense="true" Style="max-width:300px" Margin="Margin.Dense">
                                                <MudSelectItem T="string" Value="@((string?)null)">— auto (crea team dai primi 2 operatori) —</MudSelectItem>
                                                @foreach (var t in currentPlanning.Teams)
                                                {
                                                    <MudSelectItem T="string" Value="@t.Id">@string.Join(" + ", t.OperatorIds.Take(3).Select(oid => State.Operators.FirstOrDefault(o => o.Id == oid)?.FullName ?? oid))</MudSelectItem>
                                                }
                                            </MudSelect>
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                                       OnClick="@(() => { _showNewTeamForm = !_showNewTeamForm; })">
                                                @(_showNewTeamForm ? "Chiudi" : "+ Componi nuovo team")
                                            </MudButton>
                                        </div>
                                        @if (_showNewTeamForm)
                                        {
                                            <MudPaper Class="pa-2 mb-3" Outlined="true">
                                                <MudText Typo="Typo.caption" Class="mb-1"><b>Operatori:</b></MudText>
                                                <div class="resource-grid">
                                                    @foreach (var op in State.Operators)
                                                    {
                                                        var opId = op.Id;
                                                        var isSel = _newTeamOperatorIds.Contains(opId);
                                                        <div class="resource-chip @(isSel ? "selected" : "")"
                                                             @onclick="@(() => { if (isSel) _newTeamOperatorIds.Remove(opId); else _newTeamOperatorIds.Add(opId); StateHasChanged(); })">
                                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                                            <div class="resource-info">
                                                                <div class="resource-name">@op.FullName</div>
                                                            </div>
                                                            @if (isSel) { <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Primary" /> }
                                                        </div>
                                                    }
                                                </div>
                                                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="mt-2"
                                                           Disabled="@(_newTeamOperatorIds.Count == 0)"
                                                           OnClick="@(() => CreateTeamForPlanning(currentPlanning))">Crea team (@_newTeamOperatorIds.Count operatori)</MudButton>
                                            </MudPaper>
                                        }

                                        <div class="d-flex gap-2 mt-2 align-center">
                                            <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                       StartIcon="@Icons.Material.Filled.AddTask"
                                                       Disabled="@(_selectedNewMissionWoIds.Count == 0)"
                                                       OnClick="CreateMissionForSelectedWos">Crea Mission con selezione (@_selectedNewMissionWoIds.Count svc)</MudButton>
                                            <MudButton Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                                                       OnClick="@(() => { _selectedNewMissionWoIds.Clear(); StateHasChanged(); })">Deseleziona tutto</MudButton>
                                        </div>
                                    }
                                </MudCardContent>
                            </MudCard>
                        }
                    }

                    @* ── 5. SHIFTS ── *@
                    @if (GetLeadShifts().Any())
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6" Class="mb-2"><span class="bc-section-label execution">Execution</span><MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Small" /> Shift</MudText>
                        @foreach (var shift in GetLeadShifts())
                        {
                            <MudCard Class="mb-2 bc-execution-pane" Elevation="1">
                                <MudCardContent>
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudText Typo="Typo.body2"><b>Shift @shift.Id.Substring(0, Math.Min(8, shift.Id.Length))...</b></MudText>
                                        <MudChip T="string" Size="Size.Small" Color="@ShiftColor(shift.Status)">@shift.Status</MudChip>
                                        <MudSpacer />
                                        <EntityActions Kind="Shift" Ids="@(new[] { shift.Id })" Entity="shift" OnChanged="StateHasChanged" />
                                    </div>
                                    <MudText Typo="Typo.caption">Data: @shift.Date.ToString("dd/MM/yyyy") | Mission: @(shift.MissionId ?? "Unplanned")</MudText>

                                    @* ServiceEntries table *@
                                    <MudSimpleTable Dense="true" Elevation="0" Class="mt-1">
                                        <thead><tr><th>ServiceEntry</th><th>Tipo</th><th>Stato</th><th>Cliente</th><th>Azione</th><th></th></tr></thead>
                                        <tbody>
                                        @foreach (var se in shift.ServiceEntries)
                                        {
                                            <tr>
                                                <td>@se.Id.Substring(0, Math.Min(8, se.Id.Length))...</td>
                                                <td>@se.Type</td>
                                                <td><MudChip T="string" Size="Size.Small" Color="@(se.Completed ? Color.Success : Color.Default)">@(se.Completed ? "Completed" : "Da fare")</MudChip></td>
                                                <td>@(se.ClientInfo?.ClientName ?? "-")</td>
                                                <td>
                                                    @if (shift.Status == "InProgress" && !se.Completed)
                                                    {
                                                        <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                                   OnClick="@(() => CompleteServiceEntry(shift, se))">Completa</MudButton>
                                                    }
                                                </td>
                                                <td><EntityActions Kind="ServiceEntry" Ids="@(new[] { shift.Id, se.Id })" Entity="se" OnChanged="StateHasChanged" /></td>
                                            </tr>
                                        }
                                        </tbody>
                                    </MudSimpleTable>
                                    <MudText Typo="Typo.caption" Class="mt-1">Tasks: @shift.Tasks.Count</MudText>

                                    <div class="d-flex gap-2 mt-2">
                                        @if (shift.Status == "Created")
                                        {
                                            <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                       OnClick="@(() => AvviaShift(shift))">Avvia</MudButton>
                                        }
                                        @if (shift.Status == "Paused")
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">In pausa — attendo decisione Commercial</MudChip>
                                        }
                                        @if (shift.Status == "InProgress")
                                        {
                                            <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                                       OnClick="@(() => SegnalaProblema(shift))">Segnala Problema → In Pausa</MudButton>
                                            @if (shift.ServiceEntries.All(se => se.Completed) && shift.ServiceEntries.Count > 0)
                                            {
                                                <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                           OnClick="@(() => CompletaShift(shift))">Completa</MudButton>
                                            }
                                        }
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    }

                    @* ── 5. OBJECTS ── *@
                    @if (GetLeadObjects().Any())
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.h6" Class="mb-2"><span class="bc-section-label execution">Execution</span><MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" /> Oggetti</MudText>
                        <MudSimpleTable Dense="true" Elevation="0">
                            <thead><tr><th>Nome</th><th>Volume</th><th>Status</th><th>Posizione</th><th></th></tr></thead>
                            <tbody>
                            @foreach (var obj in GetLeadObjects())
                            {
                                <tr>
                                    <td>@obj.Name</td>
                                    <td>@($"{obj.Volume:F1} m3")</td>
                                    <td><MudChip T="string" Size="Size.Small" Color="@ObjColor(obj.Status.ToString())">@obj.Status</MudChip></td>
                                    <td>@(obj.Position?.WarehouseId ?? "-")</td>
                                    <td><EntityActions Kind="PhysicalObject" Ids="@(new[] { obj.Id })" Entity="obj" OnChanged="StateHasChanged" /></td>
                                </tr>
                            }
                            </tbody>
                        </MudSimpleTable>
                    }

                    @* Cross-BC traceability panel rimosso (review 2026-04-16): poco chiaro, sostituito dalla vista interattiva in /bc/instances *@

                    @* ── 7. PAYMENTS ── *@
                    @if (GetLeadPayments().Any())
                    {
                        <MudDivider Class="my-2" />
                        var recurringPayments = GetLeadPayments().Where(p => p.PaymentType == "Recurring").ToList();
                        var oneOffPayments = GetLeadPayments().Where(p => p.PaymentType != "Recurring").ToList();
                        @if (recurringPayments.Count > 0)
                        {
                            <MudText Typo="Typo.h6" Class="mb-2"><MudIcon Icon="@Icons.Material.Filled.Autorenew" Size="Size.Small" /> Pagamenti Ricorrenti (Piano)</MudText>
                            @foreach (var payment in recurringPayments)
                            {
                                @RenderPaymentCard(payment)
                            }
                        }
                        @if (oneOffPayments.Count > 0)
                        {
                            <MudText Typo="Typo.h6" Class="@($"mb-2 {(recurringPayments.Count > 0 ? "mt-3" : "")}")"><span class="bc-section-label financial">Financial</span><MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Small" /> Pagamenti Servizi</MudText>
                            @foreach (var payment in oneOffPayments)
                            {
                                @RenderPaymentCard(payment)
                            }
                        }
                    }
                }
            }

            @* ══════════════ MISSION OPERATIVE — collassabile, sotto tutto il contenuto cliente ══════════════ *@
            @{
                var opsMissions = State.Plannings
                    .SelectMany(p => p.Missions.Select(m => new { Planning = p, Mission = m }))
                    .Where(x => x.Mission.ServiceRefs.All(sr =>
                        State.WorkOrders.FirstOrDefault(w => w.Id == sr.ServiceId)?.Type == WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational))
                    .Where(x => x.Mission.ServiceRefs.Count > 0)
                    .OrderBy(x => x.Planning.Date)
                    .ToList();
                var opsWosToPlan = State.WorkOrders.Where(w => w.Type == WeTacoo.Domain.Operational.Enums.WorkOrderType.Operational
                    && w.Status is WeTacoo.Domain.Operational.Enums.WorkOrderStatus.ToSchedule
                        or WeTacoo.Domain.Operational.Enums.WorkOrderStatus.Scheduled).ToList();
            }
            @if (opsMissions.Count > 0 || opsWosToPlan.Count > 0)
            {
                <MudDivider Class="my-3" />
                <MudExpansionPanels>
                    <MudExpansionPanel>
                        <TitleContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Color="Color.Warning" />
                                <MudText Typo="Typo.subtitle1"><b>Mission Operative</b></MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@opsMissions.Count mission</MudChip>
                                @if (opsWosToPlan.Count > 0) { <MudChip T="string" Size="Size.Small" Color="Color.Error">@opsWosToPlan.Count WO da pianificare</MudChip> }
                            </div>
                        </TitleContent>
                        <ChildContent>
                            @if (opsWosToPlan.Count > 0)
                            {
                                <MudText Typo="Typo.caption" Class="mb-1"><b>WO operativi da pianificare</b> (non ancora in Mission)</MudText>
                                @foreach (var w in opsWosToPlan.Where(w => !opsMissions.Any(om => om.Mission.ServiceRefs.Any(sr => sr.ServiceId == w.Id))))
                                {
                                    <div class="d-flex align-center gap-2 mb-1">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">OPS</MudChip>
                                        <MudChip T="string" Size="Size.Small">@w.ServiceType.Type</MudChip>
                                        <MudText Typo="Typo.caption">@(w.ServiceAddress ?? "") — Area: @(State.Areas.FirstOrDefault(a => a.Id == w.ServiceType.AreaId)?.Name ?? "—") — @w.Status</MudText>
                                    </div>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"><i>Per pianificarli: sezione Planning sopra → la lista Mission li include con badge OPS.</i></MudText>
                            }
                            @if (opsMissions.Count == 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Nessuna Mission operativa.</MudText>
                            }
                            else
                            {
                                @foreach (var om in opsMissions)
                                {
                                    var hasShift = State.Shifts.Any(s => s.MissionId == om.Mission.Id);
                                    var opsShift = State.Shifts.FirstOrDefault(s => s.MissionId == om.Mission.Id);
                                    <MudPaper Class="pa-2 mb-2" Outlined="true" Style="border-left: 3px solid var(--mud-palette-warning);">
                                        <div class="d-flex align-center gap-2 flex-wrap">
                                            <MudChip T="string" Size="Size.Small" Color="@(om.Mission.IsCancelled ? Color.Error : hasShift ? Color.Success : Color.Warning)">
                                                @(om.Mission.IsCancelled ? "Cancelled" : hasShift ? "Confermata" : "Non confermata")
                                            </MudChip>
                                            <MudText Typo="Typo.caption"><b>@om.Planning.Date.ToString("dd/MM/yyyy")</b> | Mission @om.Mission.Id.Substring(0, Math.Min(8, om.Mission.Id.Length)) | @om.Mission.TimeSlot</MudText>
                                        </div>
                                        <MudText Typo="Typo.caption">Servizi:
                                        @foreach (var sr in om.Mission.ServiceRefs)
                                        {
                                            var srWo = State.WorkOrders.FirstOrDefault(w => w.Id == sr.ServiceId);
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-1">@(srWo?.ServiceType.Type.ToString() ?? "?") (@sr.VolumePercentage%)</MudChip>
                                        }
                                        </MudText>
                                        @if (!om.Mission.IsCancelled && !hasShift)
                                        {
                                            <div class="d-flex gap-2 mt-1">
                                                <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                           OnClick="@(() => ConfirmMissionShift(om.Planning, om.Mission))">Conferma → Shift</MudButton>
                                                <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                                           OnClick="@(() => DeleteMission(om.Planning, om.Mission))">Elimina</MudButton>
                                            </div>
                                        }
                                        @* Azioni Shift (come per missioni normali) *@
                                        @if (opsShift != null)
                                        {
                                            <div class="mt-2">
                                                <MudText Typo="Typo.caption"><b>Shift</b> @opsShift.Id.Substring(0, Math.Min(8, opsShift.Id.Length)) —
                                                    <MudChip T="string" Size="Size.Small" Color="@ShiftColor(opsShift.Status)">@opsShift.Status</MudChip>
                                                </MudText>
                                                <div class="d-flex gap-2 mt-1 flex-wrap">
                                                    @if (opsShift.Status == "Created")
                                                    {
                                                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                                                   OnClick="@(() => AvviaShift(opsShift))">Avvia</MudButton>
                                                    }
                                                    @if (opsShift.Status == "InProgress")
                                                    {
                                                        <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                                                   OnClick="@(() => SimulaEsecuzione(opsShift))">Simula</MudButton>
                                                        <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                                                   OnClick="@(() => SegnalaProblema(opsShift))">Segnala Problema</MudButton>
                                                    }
                                                    @if (opsShift.Status == "Paused")
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">In pausa — attendo decisione Commercial</MudChip>
                                                    }
                                                    @if (opsShift.Status == "InProgress" && opsShift.ServiceEntries.All(se => se.Completed))
                                                    {
                                                        <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                                   OnClick="@(() => CompletaShift(opsShift))">Completa Shift</MudButton>
                                                    }
                                                </div>
                                                @foreach (var se in opsShift.ServiceEntries)
                                                {
                                                    <div class="d-flex align-center gap-2 mt-1">
                                                        <MudChip T="string" Size="Size.Small" Color="@(se.Completed ? Color.Success : Color.Default)">@(se.Completed ? "Completed" : "Da fare")</MudChip>
                                                        <MudText Typo="Typo.caption">@se.Type — @(se.ServiceId.Substring(0, Math.Min(8, se.ServiceId.Length)))</MudText>
                                                        @if (opsShift.Status == "InProgress" && !se.Completed)
                                                        {
                                                            <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                                                       OnClick="@(() => CompleteServiceEntry(opsShift, se))">Completa</MudButton>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </MudPaper>
                                }
                            }
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            }
        </MudPaper>
    </MudItem>

    @* Events panel moved into left column (review 2026-04-16) *@
</MudGrid>

<style>
    .quot-section { padding: 8px 10px; border-left-width: 3px !important; background: #ffffff; }
    .quot-section.svc-section { border-left-color: #1976d2 !important; background: #eaf2fb; }
    .quot-section.prod-section { border-left-color: #7b1fa2 !important; background: #f4eaf7; }
    .quot-section.plan-section { border-left-color: #2e7d32 !important; background: #ebf4ec; }

    .quot-section-header {
        display: flex; align-items: center; gap: 8px; font-size: 0.88rem;
        font-weight: 600; color: #444; margin-bottom: 6px;
    }
    .quot-section-title { font-size: 0.95rem; color: #222; }
    .quot-section-total { font-size: 0.9rem; color: #7b1fa2; font-weight: 700; }
    .quot-section-hint { font-size: 0.72rem; color: #888; font-weight: 400; font-style: italic; margin-left: 8px; }
    .quot-section-body { padding-top: 4px; }

    .item-card { padding: 6px 10px; background: #fff; border-radius: 4px !important; }
    .item-card-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .item-card-title { font-weight: 500; color: #222; font-size: 0.9rem; }
    .item-card-sub { font-size: 0.78rem; color: #888; font-style: italic; }
    .item-card-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
    .item-card-actions { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; align-items: center; }
    .ms-auto { margin-left: auto; }

    /* ── BC color coding per le schede del Workspace ────────────────── */
    /* Commercial = blu | Operational = arancione | Execution = rosso | Financial = verde */
    /* Deal: tono blu piu' scuro; Quotation (nested): tono intermedio; Servizi/Prodotti/Piani (piu' interni): propri colori distinti */
    .bc-commercial-pane { border-left: 4px solid #1976d2 !important; background: #d6e7fa; }
    .mud-expansion-panels .mud-expansion-panels .bc-commercial-pane,
    .bc-commercial-pane .bc-commercial-pane { background: #ecf3fb !important; }
    .bc-op-pane { border-left: 4px solid #e65100 !important; background: #fff0e0; }
    .bc-execution-pane { border-left: 4px solid #c62828 !important; background: #fce7e7; }
    .bc-financial-pane { border-left: 4px solid #2e7d32 !important; background: #e3f2e4; }

    .bc-section-label {
        display: inline-block; font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.5px; padding: 2px 8px;
        border-radius: 3px; margin-right: 8px;
    }
    .bc-section-label.commercial { background: #1976d2; color: #fff; }
    .bc-section-label.op { background: #e65100; color: #fff; }
    .bc-section-label.execution { background: #c62828; color: #fff; }
    .bc-section-label.financial { background: #2e7d32; color: #fff; }

    /* ── Existing missions panel — ben separato ────────────────────── */
    .existing-missions-box {
        border: 2px dashed #e65100;
        background: #fff7f0;
        border-radius: 6px;
    }

    /* ── Resource picker (veicoli + operatori) ───────────────────────── */
    .resource-grid { display: flex; flex-wrap: wrap; gap: 8px; }
    .resource-chip {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 10px;
        background: #fff; border: 1px solid #ccc; border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s ease;
        min-width: 160px;
    }
    .resource-chip:hover { border-color: #1976d2; background: #f5faff; }
    .resource-chip.selected {
        border-color: #1976d2; background: #e3f2fd;
        box-shadow: 0 0 0 2px rgba(25, 118, 210, 0.15);
    }
    .resource-info { display: flex; flex-direction: column; line-height: 1.2; }
    .resource-name { font-weight: 500; font-size: 0.85rem; color: #222; }
    .resource-meta { font-size: 0.72rem; color: #888; }
</style>

@code {
    private static readonly Random _rng = new();
    private static readonly string[] _objectNames = ["Scatola", "Mobile", "Scrivania", "Sedia", "Lampada", "Armadio", "Scaffale", "Tavolo", "Cassettiera", "Divano"];

    // ── State fields ──
    // Selezione cliente persistente cross-navigazione (mantenuta in PlaygroundState, non resetta a navigazione)
    private string? _selectedLeadId
    {
        get => State.SelectedLeadId;
        set => State.SelectedLeadId = value;
    }

    protected override void OnParametersSet()
    {
        // Auto-select ultimo lead con deal se nulla selezionato (tipicamente dopo uno scenario)
        if (string.IsNullOrEmpty(_selectedLeadId) && State.Leads.Any(l => l.DealIds.Count > 0))
            _selectedLeadId = State.Leads.Last(l => l.DealIds.Count > 0).Id;
    }

    private bool _showNewQuotation;
    private string _quotationDealId = "";
    private bool _showInlineNewLead;
    private string _inlineLeadFirstName = "", _inlineLeadLastName = "", _inlineLeadEmail = "";

    // Quotation form
    private string? _selectedProductTemplateId;
    private List<WeTacoo.Domain.Commercial.Entities.Product> _quotationProducts = [];
    // Custom product (non-template)
    private string _customProductName = "";
    private decimal _customProductPrice;

    // Inline editing fields (existing quotations)
    private string? _inlineProductId;
    private WeTacoo.Domain.Commercial.Enums.ServiceBookedType _inlineSvcType = WeTacoo.Domain.Commercial.Enums.ServiceBookedType.Ritiro;
    private string _inlineSvcZip = "";

    // New quotation form — services + plan
    private List<WeTacoo.Domain.Commercial.Entities.ServiceBooked> _quotationServices = [];
    private WeTacoo.Domain.Commercial.Enums.ServiceBookedType? _newQuotSvcType;
    private string _newQuotSvcZip = "";
    private string _newQuotPlanDesc = "Piano deposito";
    private decimal _newQuotPlanFee = 89.90m;
    private decimal _newQuotPlanM3 = 10;
    private bool _includePlan;

    // Mission / Planning
    private int _missionVolumePercent = 100;
    private DateTime? _missionDate;
    private string _missionDateStr = "";
    private HashSet<string> _selectedVehicleIds = new();
    private string? _selectedTeamId;
    private HashSet<string> _newTeamOperatorIds = new();
    private bool _showNewTeamForm;
    private string _missionTimeSlot = "09:00-12:00";
    private HashSet<string> _selectedNewMissionWoIds = new();

    // ── Nuovo WorkOrder operativo (Trasferimento / Trasbordo) ──
    private bool _showOpsWoForm;
    private WeTacoo.Domain.Operational.Enums.ServiceTypeEnum _opsWoServiceType = WeTacoo.Domain.Operational.Enums.ServiceTypeEnum.Trasferimento;
    private string? _opsWoAreaId;
    private string _opsWoAddress = "";
    private decimal _opsWoVolume = 5m;

    // Vehicle selection for mission
    private string? _selectedVehicleId;

    // Payment creation
    private decimal _newPaymentAmount;
    private string _newPaymentType = "OneOff";

    // ── State subscription ──
    private Action _onStateChanged = null!;
    protected override void OnInitialized() { _onStateChanged = () => InvokeAsync(StateHasChanged); State.OnStateChanged += _onStateChanged; }
    public void Dispose() => State.OnStateChanged -= _onStateChanged;

    // ══════════════════════════════════════════════════════════════
    // QUICK ACTION DIALOG
    // ══════════════════════════════════════════════════════════════
    async Task OpenQuickAction(string preset)
    {
        var parameters = new DialogParameters<QuickActionDialog> { { x => x.Preset, preset } };
        var dialog = await DialogService.ShowAsync<QuickActionDialog>(preset == "deposito" ? "Nuovo Deposito" : "Nuovo Trasloco", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled && result.Data is string leadId)
            _selectedLeadId = leadId;
    }

    // ══════════════════════════════════════════════════════════════
    // RESET
    // ══════════════════════════════════════════════════════════════
    private void ResetAll()
    {
        State.Reset();
        _selectedLeadId = null;
        Snackbar.Add("Playground resettato", Severity.Info);
    }

    // ══════════════════════════════════════════════════════════════
    // LEAD ACTIONS
    // ══════════════════════════════════════════════════════════════
    private void SelectLead(string id) => _selectedLeadId = id;

    private void CreateInlineLead()
    {
        var lead = new WeTacoo.Domain.Commercial.Lead
        {
            Personal = new WeTacoo.Domain.Commercial.ValueObjects.Personal(_inlineLeadFirstName, _inlineLeadLastName, _inlineLeadEmail, "")
        };
        State.Leads.Add(lead);
        State.PublishEvent(new WeTacoo.Domain.Events.LeadCreatedEvent(lead.Id));

        var user = new WeTacoo.Domain.Identity.User { Email = _inlineLeadEmail, Role = "Customer" };
        State.Users.Add(user);
        lead.IdentityId = user.Id;

        var mkt = new WeTacoo.Domain.Marketing.MarketingClient { CommercialLeadId = lead.Id, FunnelStep = "LeadCreated" };
        State.MarketingClients.Add(mkt);

        _selectedLeadId = lead.Id;
        _showInlineNewLead = false;
        _inlineLeadFirstName = _inlineLeadLastName = _inlineLeadEmail = "";
        Snackbar.Add($"Lead {lead.Personal.FirstName} {lead.Personal.LastName} creato", Severity.Success);
        State.NotifyStateChanged();
    }

